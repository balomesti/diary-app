@namespace diary_app.Component.Shared

<div class="form-group">
    <label class="field-label">How are you feeling?</label>
    <div class="mood-row">

        <label class="mood-chip @(Mood == "terrible" ? "active-terrible" : "")">
            <input type="radio" name="mood" value="terrible"
                   checked="@(Mood == "terrible")"
                   @onchange='() => SetMood("terrible")' />
            <div class="mood-icon-wrap">
                <svg class="face-svg" viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="18" fill="#FCD34D" stroke="#F59E0B" stroke-width="1.2"/>
                    <ellipse cx="13.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <ellipse cx="26.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <path d="M10.5 11.5 Q13.5 10 15 11.5" stroke="#92400E" stroke-width="1.4" fill="none" stroke-linecap="round"/>
                    <path d="M25 11.5 Q26.5 10 29.5 11.5" stroke="#92400E" stroke-width="1.4" fill="none" stroke-linecap="round"/>
                    <path d="M13 27 Q20 22 27 27" stroke="#92400E" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                    <ellipse class="tear tear-l" cx="12" cy="20" rx="1.5" ry="2.5" fill="#60A5FA"/>
                    <ellipse class="tear tear-r" cx="29" cy="20" rx="1.5" ry="2.5" fill="#60A5FA"/>
                </svg>
            </div>
            <span class="mood-label">Terrible</span>
        </label>

        <label class="mood-chip @(Mood == "bad" ? "active-bad" : "")">
            <input type="radio" name="mood" value="bad"
                   checked="@(Mood == "bad")"
                   @onchange='() => SetMood("bad")' />
            <div class="mood-icon-wrap">
                <svg class="face-svg" viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="18" fill="#FCD34D" stroke="#F59E0B" stroke-width="1.2"/>
                    <ellipse cx="13.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <ellipse cx="26.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <rect class="bad-lid" x="10.7" y="13.5" width="5.6" height="3" rx="1.5" fill="#FCD34D"/>
                    <rect class="bad-lid" x="23.7" y="13.5" width="5.6" height="3" rx="1.5" fill="#FCD34D"/>
                    <path d="M14 26 Q20 23 26 26" stroke="#92400E" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="mood-label">Bad</span>
        </label>

        <label class="mood-chip @(Mood == "okay" ? "active-okay" : "")">
            <input type="radio" name="mood" value="okay"
                   checked="@(Mood == "okay")"
                   @onchange='() => SetMood("okay")' />
            <div class="mood-icon-wrap">
                <svg class="face-svg" viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="18" fill="#FCD34D" stroke="#F59E0B" stroke-width="1.2"/>
                    <ellipse class="okay-blink" cx="13.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <ellipse class="okay-blink" cx="26.5" cy="16" rx="2.8" ry="3" fill="#1C1917"/>
                    <line class="okay-mouth" x1="14" y1="25.5" x2="26" y2="25.5" stroke="#92400E" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="mood-label">Okay</span>
        </label>

        <label class="mood-chip @(Mood == "good" ? "active-good" : "")">
            <input type="radio" name="mood" value="good"
                   checked="@(Mood == "good")"
                   @onchange='() => SetMood("good")' />
            <div class="mood-icon-wrap">
                <svg class="face-svg" viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="18" fill="#FCD34D" stroke="#F59E0B" stroke-width="1.2"/>
                    <path d="M11 16 Q13.5 13 16 16" stroke="#1C1917" stroke-width="2" fill="none" stroke-linecap="round"/>
                    <path d="M24 16 Q26.5 13 29 16" stroke="#1C1917" stroke-width="2" fill="none" stroke-linecap="round"/>
                    <path d="M12 23 Q20 31 28 23" stroke="#92400E" stroke-width="2" fill="#F97316" stroke-linecap="round"/>
                    <circle class="blush" cx="9"  cy="22" r="3.5" fill="#FCA5A5" opacity="0.4"/>
                    <circle class="blush" cx="31" cy="22" r="3.5" fill="#FCA5A5" opacity="0.4"/>
                </svg>
            </div>
            <span class="mood-label">Good</span>
        </label>

        <label class="mood-chip @(Mood == "amazing" ? "active-amazing" : "")">
            <input type="radio" name="mood" value="amazing"
                   checked="@(Mood == "amazing")"
                   @onchange='() => SetMood("amazing")' />
            <div class="mood-icon-wrap">
                <div class="stars-wrap">
                    <span class="star-main">⭐</span>
                    <span class="star-small s1">✦</span>
                    <span class="star-small s2">✦</span>
                    <span class="star-small s3">✦</span>
                </div>
            </div>
            <span class="mood-label">Amazing</span>
        </label>

    </div>
</div>

@code {
    [Parameter]
    public string Mood { get; set; } = "good";

    [Parameter]
    public EventCallback<string> MoodChanged { get; set; }

    private async Task SetMood(string mood)
    {
        Mood = mood;
        await MoodChanged.InvokeAsync(mood);
    }
}
