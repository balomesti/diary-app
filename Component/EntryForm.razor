@using Microsoft.AspNetCore.Components.Forms
@using diary_app.Models
@inherits ComponentBase

<div class="entry-container">
    <!-- TOP HEADER -->
    <div class="entry-header">
        <h1>@(IsEdit ? "Edit Diary Entry" : "New Diary Entry")</h1>
        <p>@(IsEdit ? "Update your thoughts and experiences" : "Capture your thoughts and experiences here")</p>
        
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="header-buttons">
            <button class="btn-outline" type="button" @onclick="OnCancel">Cancel</button>
            <button class="btn-solid" type="submit" form="entry-form" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span>Saving...</span>
                }
                else
                {
                    <span>@(IsEdit ? "Save Changes" : "Save Entry")</span>
                }
            </button>
        </div>
    </div>

    <!-- FORM SECTION -->
    <EditForm Model="Entry" OnValidSubmit="HandleSubmit" id="entry-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label>Title</label>
            <InputText @bind-Value="Entry.Title" class="form-control" placeholder="Enter the title of your entry" />
        </div>

        <div class="form-group">
            <label>Comment</label>
            <InputTextArea @bind-Value="Entry.Content" class="form-control" placeholder="Write your thoughts..." />
        </div>

        <div class="form-group">
            <label>Date</label>
            <InputDate @bind-Value="Entry.Date" class="form-control" />
            <div class="help-text">Format: YYYY-MM-DD</div>
        </div>

        <div class="form-group">
            <label>Image</label>
            <InputFile OnChange="HandleFileSelected" accept="image/*" />
            <div class="help-text">@(IsEdit ? "Optional: select to replace image" : "Optional: Add a related image")</div>
            
            @if (!string.IsNullOrEmpty(imagePreviewUrl))
            {
                <div class="image-preview-container">
                    <img src="@imagePreviewUrl" alt="Image Preview" class="image-preview" />
                    <button type="button" class="btn-remove-image" @onclick="RemoveImage">Remove</button>
                </div>
            }
            else if (IsEdit && !string.IsNullOrEmpty(Entry.ImageUrl))
            {
                <div class="image-preview-container">
                    <img src="@($"http://localhost:5105{Entry.ImageUrl}")" alt="Current Image" class="image-preview" />
                    <div class="help-text" style="text-align: center;">Current Image</div>
                </div>
            }
        </div>

        <!-- BOTTOM ACTIONS -->
        <div class="submit-section">
            <button type="submit" class="btn-solid" disabled="@IsSubmitting">
                @(IsSubmitting ? "Submitting..." : "Submit")
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public DiaryEntry Entry { get; set; } = new DiaryEntry();
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string ErrorMessage { get; set; } = string.Empty;
    [Parameter] public Func<DiaryEntry, IBrowserFile?, Task<bool>> OnSave { get; set; } = default!;
    [Parameter] public EventCallback OnCancel { get; set; }

    private IBrowserFile? _selectedImage;
    private string? imagePreviewUrl;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedImage = e.File;
        
        if (_selectedImage != null)
        {
            // Read the file and convert it to a base64 string for preview
            var format = _selectedImage.ContentType;
            var maxAllowedSize = 5120000; // 5MB limit for preview
            
            try
            {
                var buffer = new byte[_selectedImage.Size];
                await _selectedImage.OpenReadStream(maxAllowedSize).ReadAsync(buffer);
                imagePreviewUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error reading file: {ex.Message}");
                imagePreviewUrl = null;
            }
        }
        else
        {
            imagePreviewUrl = null;
        }
    }

    private void RemoveImage()
    {
        _selectedImage = null;
        imagePreviewUrl = null;
        // Note: Clearing the actual <input type="file"> value is tricky in Blazor without JS interop, 
        // but setting _selectedImage to null prevents it from being sent on save.
    }

    private async Task HandleSubmit()
    {
        if (OnSave != null)
        {
            await OnSave.Invoke(Entry, _selectedImage);
        }
    }
}
