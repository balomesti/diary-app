@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using diary_app.Models
@inject IJSRuntime JS
@inherits ComponentBase

<div class="entry-container @Size">
    <div class="entry-header">
        <h1>@(IsEdit ? "Edit Diary Entry" : "New Diary Entry")</h1>
        <p>@(IsEdit ? "Update your thoughts and experiences" : "Capture your thoughts and experiences here")</p>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
    </div>

    <EditForm Model="Entry" OnValidSubmit="HandleSubmit" id="entry-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- Title spans full width -->
        <div class="form-group title-group">
            <label>Title</label>
            <InputText @bind-Value="Entry.Title" class="form-control" placeholder="Give your entry a title..." />
        </div>

        <!-- Two-column layout: sidebar + main -->
        <div class="form-layout">

            <!-- LEFT SIDEBAR: metadata -->
            <aside class="form-sidebar">

                <div class="sidebar-card">
                    <div class="sidebar-card-title">📅 Date</div>
                    <InputDate @bind-Value="Entry.Date" class="form-control" />
                </div>

                <div class="sidebar-card">
                    <div class="sidebar-card-title">📍 Location</div>
                    <div class="weather-row">
                        <InputText @bind-Value="Location" class="form-control" placeholder="E.g. Kuala Lumpur, Malaysia" />
                        <button type="button" class="btn-weather" @onclick="DetectLocation" title="Auto-detect location">
                            <span aria-hidden="true">📍</span>
                        </button>
                    </div>
                    @if (LocationLoading)
                    {
                        <div class="help-text">Detecting...</div>
                    }
                </div>

                <div class="sidebar-card">
                    <div class="sidebar-card-title">⛅ Weather</div>
                    <div class="weather-row">
                        <InputText @bind-Value="Weather" class="form-control" placeholder="E.g. 32°C, Sunny" />
                        <button type="button" class="btn-weather" @onclick="DetectWeather" title="Auto-detect weather">
                            <span aria-hidden="true">⛅</span>
                        </button>
                    </div>
                    @if (WeatherLoading)
                    {
                        <div class="help-text">Detecting...</div>
                    }
                </div>

                <!-- TAGS: preset buttons + custom input -->
                <div class="sidebar-card">
                    <div class="sidebar-card-title">🏷️ Tags</div>

                    <!-- Preset tag buttons -->
                    <div class="preset-tags">
                        @foreach (var preset in PresetTags)
                        {
                            var isSelected = Tags.Contains(preset.Label, StringComparer.OrdinalIgnoreCase);
                            <button type="button"
                                    class="preset-tag @(isSelected ? "preset-tag--active" : "")"
                                    @onclick="() => TogglePresetTag(preset.Label)">
                                @preset.Icon @preset.Label
                            </button>
                        }
                    </div>

                    <!-- Custom tag input -->
                    <InputText @bind-Value="TagInput"
                               class="form-control"
                               placeholder="Custom tag, press Enter"
                               @onkeydown="HandleTagKeyDown" />

                    <!-- Selected tags -->
                    @if (Tags.Any())
                    {
                        <div class="tags-container">
                            @foreach (var tag in Tags)
                            {
                                <div class="tag-pill">
                                    @tag <span class="tag-remove" @onclick="() => RemoveTag(tag)">&times;</span>
                                </div>
                            }
                        </div>
                    }
                </div>

            </aside>

            <!-- RIGHT MAIN: mood, content, images -->
            <main class="form-main">

                <div class="form-group">
                    <label>How are you feeling?</label>
                    <div class="mood-selector">
                        <label class="mood-option">
                            <input type="radio" name="mood" value="terrible" checked="@(Mood == "terrible")" @onchange='() => ChangeMood("terrible")' />
                            <div class="mood-content">
                                <span class="mood-emoji">😢</span>
                                <span class="mood-text">Terrible</span>
                            </div>
                        </label>
                        <label class="mood-option">
                            <input type="radio" name="mood" value="bad" checked="@(Mood == "bad")" @onchange='() => ChangeMood("bad")' />
                            <div class="mood-content">
                                <span class="mood-emoji">😕</span>
                                <span class="mood-text">Bad</span>
                            </div>
                        </label>
                        <label class="mood-option">
                            <input type="radio" name="mood" value="okay" checked="@(Mood == "okay")" @onchange='() => ChangeMood("okay")' />
                            <div class="mood-content">
                                <span class="mood-emoji">😐</span>
                                <span class="mood-text">Okay</span>
                            </div>
                        </label>
                        <label class="mood-option">
                            <input type="radio" name="mood" value="good" checked="@(Mood == "good")" @onchange='() => ChangeMood("good")' />
                            <div class="mood-content">
                                <span class="mood-emoji">😊</span>
                                <span class="mood-text">Good</span>
                            </div>
                        </label>
                        <label class="mood-option">
                            <input type="radio" name="mood" value="amazing" checked="@(Mood == "amazing")" @onchange='() => ChangeMood("amazing")' />
                            <div class="mood-content">
                                <span class="mood-emoji">✨</span>
                                <span class="mood-text">Amazing</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Comment</label>
                    <InputTextArea @bind-Value="Entry.Content" class="form-control" placeholder="Write your thoughts..." />
                </div>

                <div class="form-group">
                    <label>📷 Images</label>
                    <InputFile OnChange="HandleFileSelected" accept="image/*" multiple />
                    @if (imagePreviewUrls.Any())
                    {
                        <div class="image-previews-grid">
                            @foreach (var url in imagePreviewUrls)
                            {
                                <div class="image-preview-container">
                                    <img src="@url" alt="Image Preview" class="image-preview" />
                                </div>
                            }
                        </div>
                        <button type="button" class="btn-outline btn-clear" @onclick="RemoveImages">Clear All</button>
                    }
                    else if (IsEdit && !string.IsNullOrEmpty(Entry.ImageUrls))
                    {
                        <div class="image-previews-grid">
                            @foreach (var url in Entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <div class="image-preview-container">
                                    <img src="@($"http://localhost:5105{url}")" alt="Current Image" class="image-preview" />
                                </div>
                            }
                        </div>
                        <div class="help-text" style="text-align:center; margin-top: 8px;">Current Images</div>
                    }
                </div>

            </main>
        </div>

        <div class="submit-section">
            <button type="button" class="btn-outline" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            <button type="submit" class="btn-solid" disabled="@IsSubmitting">
               @(IsSubmitting ? "Submitting..." : "Submit Entry")
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public DiaryEntry Entry { get; set; } = new DiaryEntry();
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string ErrorMessage { get; set; } = string.Empty;
    [Parameter] public Func<DiaryEntry, List<ImageFileData>?, Task<bool>> OnSave { get; set; } = default!;
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string Size { get; set; } = "normal";

    private List<ImageFileData> _selectedImages = new();
    private List<string> imagePreviewUrls = new();

    private string Location { get; set; } = string.Empty;
    private string Weather { get; set; } = string.Empty;
    private string Mood { get; set; } = "good";
    private string TagInput { get; set; } = string.Empty;
    private List<string> Tags { get; set; } = new();
    private bool WeatherLoading { get; set; }
    private bool LocationLoading { get; set; }

    private record PresetTag(string Icon, string Label);

    private readonly List<PresetTag> PresetTags = new()
    {
        new("💼", "Work"),
        new("🍽️", "Food"),
        new("✈️", "Travel"),
        new("🏋️", "Exercise"),
        new("👨‍👩‍👧", "Family"),
        new("👫", "Social"),
        new("📚", "Study"),
        new("🎉", "Special"),
        new("💊", "Health"),
        new("💰", "Finance"),
    };

    private void TogglePresetTag(string label)
    {
        if (Tags.Contains(label, StringComparer.OrdinalIgnoreCase))
            Tags.RemoveAll(t => t.Equals(label, StringComparison.OrdinalIgnoreCase));
        else
            Tags.Add(label);
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var newFiles = e.GetMultipleFiles().ToList();
        foreach (var file in newFiles)
        {
            var maxAllowedSize = 5120000;
            using var stream = file.OpenReadStream(maxAllowedSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();

            _selectedImages.Add(new ImageFileData
            {
                FileName = file.Name,
                ContentType = file.ContentType,
                Data = buffer
            });

            var format = file.ContentType;
            imagePreviewUrls.Add($"data:{format};base64,{Convert.ToBase64String(buffer)}");
        }
    }

    private void RemoveImages()
    {
        _selectedImages.Clear();
        imagePreviewUrls.Clear();
    }

    private void HandleTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(TagInput))
        {
            var tag = TagInput.Trim();
            if (!Tags.Contains(tag, StringComparer.OrdinalIgnoreCase))
                Tags.Add(tag);
            TagInput = string.Empty;
        }
    }

    private void RemoveTag(string tag) => Tags.Remove(tag);
    private void ChangeMood(string mood) => Mood = mood;

    private async Task DetectLocation()
    {
        LocationLoading = true;
        try
        {
            var position = await JS.InvokeAsync<GeolocationResult>("getCurrentPosition");
            if (position?.Coords != null)
            {
                var lat = position.Coords.latitude;
                var lon = position.Coords.longitude;
                var url = $"https://nominatim.openstreetmap.org/reverse?lat={lat}&lon={lon}&format=json";
                using var httpClient = new HttpClient();
                httpClient.DefaultRequestHeaders.Add("User-Agent", "DiaryApp/1.0");
                var json = await httpClient.GetStringAsync(url);
                var data = System.Text.Json.JsonDocument.Parse(json);
                var root = data.RootElement;
                var city = root.TryGetProperty("city", out var c) ? c.GetString() :
                           root.TryGetProperty("town", out var t) ? t.GetString() :
                           root.TryGetProperty("village", out var v) ? v.GetString() :
                           root.TryGetProperty("municipality", out var m) ? m.GetString() : null;
                var country = root.TryGetProperty("country", out var co) ? co.GetString() : null;
                if (!string.IsNullOrEmpty(city) && !string.IsNullOrEmpty(country))
                    Location = $"{city}, {country}";
                else if (!string.IsNullOrEmpty(country))
                    Location = country;
                else
                    Location = "Unknown location";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Location detection failed: {ex.Message}");
            Location = "Unable to detect";
        }
        finally { LocationLoading = false; }
    }

    private async Task DetectWeather()
    {
        WeatherLoading = true;
        try
        {
            var position = await JS.InvokeAsync<GeolocationResult>("getCurrentPosition");
            if (position?.Coords != null)
            {
                var lat = position.Coords.latitude;
                var lon = position.Coords.longitude;
                var url = $"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,weather_code&wind_speed_unit=ms";
                using var httpClient = new HttpClient();
                var json = await httpClient.GetStringAsync(url);
                var data = System.Text.Json.JsonDocument.Parse(json);
                var root = data.RootElement;
                var temp = root.GetProperty("current").GetProperty("temperature_2m").GetDouble();
                var wcode = root.GetProperty("current").GetProperty("weather_code").GetInt32();
                Weather = $"{temp}°C, {GetWeatherCondition(wcode)}";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Weather detection failed: {ex.Message}");
            Weather = "Unable to detect";
        }
        finally { WeatherLoading = false; }
    }

    private static string GetWeatherCondition(int code) => code switch
    {
        0 => "Clear",
        1 or 2 or 3 => "Partly Cloudy",
        45 or 48 => "Foggy",
        51 or 53 or 55 => "Drizzle",
        61 or 63 or 65 => "Rainy",
        66 or 67 => "Freezing Rain",
        71 or 73 or 75 => "Snowy",
        77 => "Snow Grains",
        80 or 81 or 82 => "Rain Showers",
        85 or 86 => "Snow Showers",
        95 => "Thunderstorm",
        96 or 99 => "Thunderstorm with Hail",
        _ => "Unknown"
    };

    protected override void OnInitialized()
    {
        Location = Entry.Location ?? "";
        Weather = Entry.Weather ?? "";
        Mood = string.IsNullOrEmpty(Entry.Mood) ? "good" : Entry.Mood;
        if (!string.IsNullOrWhiteSpace(Entry.Tags))
        {
            Tags = Entry.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries)
                             .Select(t => t.Trim())
                             .ToList();
        }
    }

    private async Task HandleSubmit()
    {
        Entry.Location = Location ?? "";
        Entry.Weather = Weather ?? "";
        Entry.Mood = Mood ?? "";
        Entry.Tags = string.Join(",", Tags);
        if (OnSave != null)
            await OnSave.Invoke(Entry, _selectedImages.Any() ? _selectedImages : null);
    }
}
