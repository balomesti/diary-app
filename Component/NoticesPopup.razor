@inject DiaryService DiaryService
@inject IJSRuntime JS

<div style="position: relative;" @onclick:stopPropagation="true">
    <button type="button" class="icon-btn notification-btn" aria-label="Notifications" aria-haspopup="@(IsMobile ? null : "dialog")" aria-expanded="@(IsMobile ? null : isOpen.ToString().ToLower())" aria-controls="@(IsMobile ? null : "notices-dropdown")" @onclick="ToggleAsync">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 8a6 6 0 10-12 0c0 7-3 7-3 7h18s-3 0-3-7" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
            <path d="M13.73 21a2 2 0 01-3.46 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        @if (unreadCount > 0)
        {
            <span class="notification-badge">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
        }
    </button>

    @if (isOpen)
    {
        <div style="position: fixed; inset: 0; z-index: 2000;" @onclick="Close">
            <div id="notices-dropdown" style="position: absolute; top: 64px; right: 18px; width: min(420px, calc(100vw - 36px)); max-height: min(520px, calc(100vh - 96px)); overflow: auto; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 14px; box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18); padding: 14px;" @onclick:stopPropagation="true" role="dialog" aria-label="Notifications list">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px;">
                    <div style="font-weight: 800; font-size: 1.05rem; color: #0f172a;">Notices</div>
                    <button type="button" class="navmenu-link" style="padding: 8px 12px; border: 1px solid #e5e7eb;" aria-label="Close notifications" @onclick="Close">Close</button>
                </div>

                @if (!string.IsNullOrEmpty(loadError))
                {
                    <div style="padding: 12px; border-radius: 12px; background: #fee2e2; color: #991b1b; font-weight: 700;">
                        @loadError
                    </div>
                }
                else if (isLoading)
                {
                    <div style="padding: 12px; color: #334155; font-weight: 700;">
                        Loading...
                    </div>
                }
                else if (notices.Count == 0)
                {
                    <div style="padding: 12px; color: #334155; font-weight: 700;">
                        No notices.
                    </div>
                }
                else
                {
                    @foreach (var item in notices)
                    {
                        <div style="padding: 12px; border: 1px solid #e5e7eb; border-radius: 12px; background: #fff; margin-bottom: 10px;">
                            <div style="font-weight: 900; color: #0f172a; margin-bottom: 6px;">@item.Title</div>
                            <div style="color: #334155; line-height: 1.45;">@item.Message</div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<style>
    .notification-btn {
        position: relative;
    }

    .notification-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background-color: #ef4444;
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        border: 2px solid white;
        pointer-events: none;
    }
</style>

@code {
    [Parameter] public bool IsMobile { get; set; } = false;

    private bool isOpen;
    private bool isLoading;
    private string loadError = "";
    private int unreadCount = 0;
    private List<NoticeDto> notices = new();
    private const string LastReadKey = "diary_notices_last_read";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshUnreadCountAsync();
        }
    }

    private async Task RefreshUnreadCountAsync()
    {
        try
        {
            var allNotices = await DiaryService.GetAdminListAsync<NoticeDto>("api/Admin/announcements");
            var lastReadStr = await JS.InvokeAsync<string?>("localStorage.getItem", LastReadKey);
            DateTime lastRead = string.IsNullOrEmpty(lastReadStr) ? DateTime.MinValue : DateTime.Parse(lastReadStr);

            unreadCount = allNotices.Count(n => n.CreatedAt > lastRead);
            StateHasChanged();
        }
        catch
        {
            unreadCount = 0;
        }
    }

    private async Task ToggleAsync()
    {
        if (isOpen)
        {
            isOpen = false;
            return;
        }

        isOpen = true;
        await LoadAsync();

        unreadCount = 0;
        StateHasChanged();
        await JS.InvokeVoidAsync("localStorage.setItem", LastReadKey, DateTime.UtcNow.ToString("O"));
    }

    private void Close()
    {
        isOpen = false;
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            notices = await DiaryService.GetAdminListAsync<NoticeDto>("api/Admin/announcements");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private sealed class NoticeDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
