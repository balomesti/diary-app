@using diary_app.Models

<div class="badges-grid">
    @foreach (var badge in Badges)
    {
        <div class="badge-card @(badge.IsUnlocked ? "unlocked" : "locked")">
            <div class="badge-wrap">

                @if (badge.Title == "10 Entries" && badge.IsUnlocked)
                {
                    <div class="gleam gleam-t"></div>
                    <div class="gleam gleam-tr"></div>
                    <div class="gleam gleam-tl"></div>
                }
                @if (badge.Title == "35 Entries" && badge.IsUnlocked)
                {
                    <div class="ring"></div>
                }

                <div class="badge-icon @GetAnimClass(badge)">
                    <i class="@badge.IconClass"></i>

                    @if (badge.Title == "Photo Buff" && badge.IsUnlocked)
                    {
                        <div class="shutter-flash"></div>
                    }
                    @if (badge.Title == "20 Entries" && badge.IsUnlocked)
                    {
                        <div class="ink">
                            <div class="ink-dot"></div>
                            <div class="ink-dot"></div>
                            <div class="ink-dot"></div>
                            <div class="ink-dot"></div>
                            <div class="ink-dot"></div>
                        </div>
                    }
                </div>
            </div>
            <div class="badge-title">@badge.Title</div>
            @if (!badge.IsUnlocked)
            {
                <div class="badge-locked-label">Locked</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<Badge> Badges { get; set; } = new List<Badge>();

    private string GetAnimClass(Badge badge) => badge.IsUnlocked ? badge.Title switch
    {
        "First Entry" => "anim-grow",
        "7 Days"      => "anim-tick",
        "Photo Buff"  => "anim-shutter",
        "10 Entries"  => "anim-spin",
        "20 Entries"  => "anim-pen",
        "35 Entries"  => "anim-star",
        _             => ""
    } : "";
}