@inject DiaryService DiaryService

@if (IsLoading)
{
    <section class="stats-row">
        <div class="stat-card skeleton">
            <div class="stat-body">
                <span class="stat-value skeleton-text"></span>
                <span class="stat-label">Day streak</span>
            </div>
        </div>
        <div class="stat-card skeleton">
            <div class="stat-body">
                <span class="stat-value skeleton-text"></span>
                <span class="stat-label">Total entries</span>
            </div>
        </div>
        <div class="stat-card skeleton">
            <div class="stat-body">
                <span class="stat-label">Avg mood</span>
            </div>
        </div>
    </section>
}
else
{
    <section class="stats-row">
        <div class="stat-card">
            <span class="stat-icon">🔥</span>
            <div class="stat-body">
                <span class="stat-value">@Streak</span>
                <span class="stat-label">Day streak</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <span class="stat-value">@Total</span>
                <span class="stat-label">Total entries</span>
            </div>
        </div>
        <div class="stat-card">
            <span class="stat-icon">@AvgMood</span>
            <div class="stat-body">
                <span class="stat-label">Avg mood</span>
            </div>
        </div>
    </section>

    @if (dayStats.Any(d => d.Count > 0))
    {
        <section class="mood-chart-section">
            <div class="wdc-card">
                <div class="wdc-header">
                    <span class="wdc-title">BEST WRITING DAYS</span>
                    <span class="wdc-subtitle">entries per day of week</span>
                </div>

                <div class="wdc-chart">
                    @foreach (var day in dayStats)
                    {
                        <div class="wdc-col @(day.IsToday ? "wdc-today" : "")">
                            <!-- Bar -->
                            <div class="wdc-bar-wrap">
                                <span class="wdc-count">@day.Count</span>
                                <div class="wdc-bar-track">
                                    <div class="wdc-bar-fill"
                                         style="height: @(day.HeightPercent)%; background: @day.BarColor;">
                                    </div>
                                </div>
                            </div>

                            <!-- Mood emoji -->
                            <div class="wdc-mood" title="Avg mood: @day.AvgMoodLabel">
                                @day.MoodEmoji
                            </div>

                            <!-- Day label -->
                            <div class="wdc-label">@day.ShortName</div>

                            @if (day.IsBest)
                            {
                                <div class="wdc-best-tag">best</div>
                            }
                        </div>
                    }
                </div>

                <!-- Insights Box -->
                @if (!string.IsNullOrEmpty(insightsText))
                {
                    <div class="wdc-insights">
                        <p>@((MarkupString)insightsText)</p>
                    </div>
                }

                <!-- Legend -->
                <div class="wdc-legend">
                    <div class="wdc-legend-item">
                        <span class="wdc-legend-dot" style="background: #2d5a3d;"></span>
                        <span>More entries</span>
                    </div>
                    <div class="wdc-legend-item">
                        <span class="wdc-legend-dot" style="background: #c8e6d4;"></span>
                        <span>Fewer entries</span>
                    </div>
                    <div class="wdc-legend-item">
                        <span>emoji = avg mood that day</span>
                    </div>
                </div>
            </div>
        </section>
    }
}

@code {
    private bool IsLoading = true;
    private int Streak;
    private int Total;
    private string AvgMood = "🙂";

    private List<DayStat> dayStats = new();
    private string insightsText = "";

    private record DayStat(
        string ShortName,
        int Count,
        double AvgMoodScore,
        string MoodEmoji,
        string AvgMoodLabel,
        double HeightPercent,
        string BarColor,
        bool IsBest,
        bool IsToday
    );

    protected override async Task OnInitializedAsync()
    {
        var entries = await DiaryService.GetEntriesAsync();
        var sorted = entries.OrderByDescending(e => e.Date).ToList();
        Total = sorted.Count;
        Streak = CalculateStreak(sorted);
        AvgMood = CalculateAvgMood(sorted);
        BuildWritingStats(sorted);
        IsLoading = false;
    }

    private static int CalculateStreak(List<DiaryEntry> sorted)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var streak = 0;
        var expected = today;
        foreach (var e in sorted)
        {
            var d = DateOnly.FromDateTime(e.Date);
            if (d == expected) { streak++; expected = expected.AddDays(-1); }
            else if (d < expected) break;
        }
        return streak;
    }

    private static string CalculateAvgMood(List<DiaryEntry> entries)
    {
        var scores = entries.Where(e => !string.IsNullOrEmpty(e.Mood)).Select(e => MoodValue(e.Mood)).ToList();
        if (!scores.Any()) return "🙂";
        var avg = scores.Average();
        if (avg < 1.5) return "😭";
        if (avg < 2.5) return "😕";
        if (avg < 3.5) return "😐";
        if (avg < 4.5) return "🙂";
        return "✨";
    }

    private static double MoodValue(string mood)
    {
        switch (mood.ToLower())
        {
            case "terrible": return 1;
            case "bad": return 2;
            case "okay": return 3;
            case "good": return 4;
            case "amazing": return 5;
            default: return 3;
        }
    }

    private void BuildWritingStats(List<DiaryEntry> entries)
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var dotNetDays = new[] {
            DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
            DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
        };
        var todayDow = DateTime.Today.DayOfWeek;

        var grouped = entries
            .GroupBy(e => e.Date.DayOfWeek)
            .ToDictionary(g => g.Key, g => g.ToList());

        var counts = dotNetDays.Select(d => grouped.ContainsKey(d) ? grouped[d].Count : 0).ToList();
        int maxCount = counts.Max() == 0 ? 1 : counts.Max();
        int minCount = counts.Where(c => c > 0).DefaultIfEmpty(0).Min();
        int bestIndex = counts.IndexOf(counts.Max());

        // Green ramp: low = #c8e6d4, high = #2d5a3d
        var colorStops = new[] { "#c8e6d4", "#9aced4", "#6ab8a0", "#3d9970", "#2d5a3d" };

        dayStats = dotNetDays.Select((dow, i) =>
        {
            var entriesForDay = grouped.ContainsKey(dow) ? grouped[dow] : new List<DiaryEntry>();
            int count = entriesForDay.Count;
            double heightPct = maxCount > 0 ? Math.Max(4, (count / (double)maxCount) * 100) : 4;

            double avgScore = entriesForDay
                .Where(e => !string.IsNullOrEmpty(e.Mood))
                .Select(e => MoodValue(e.Mood))
                .DefaultIfEmpty(3)
                .Average();

            int colorIndex = count == 0 ? 0 : (int)Math.Round((count / (double)maxCount) * 4);
            colorIndex = Math.Clamp(colorIndex, 0, 4);

            return new DayStat(
                ShortName: days[i],
                Count: count,
                AvgMoodScore: avgScore,
                MoodEmoji: GetMoodEmoji(avgScore),
                AvgMoodLabel: GetMoodLabel(avgScore),
                HeightPercent: heightPct,
                BarColor: colorStops[colorIndex],
                IsBest: i == bestIndex && count > 0,
                IsToday: dow == todayDow
            );
        }).ToList();

        // Build Insights
        if (dayStats.Any(d => d.Count > 0))
        {
            var bestDay = dayStats[bestIndex];
            var happiestDay = dayStats.OrderByDescending(d => d.AvgMoodScore).First(d => d.Count > 0);
            var leastDay = dayStats.Where(d => d.Count > 0).OrderBy(d => d.Count).First();

            var fullDayNames = new Dictionary<string, string> {
                {"Mon", "Mondays"}, {"Tue", "Tuesdays"}, {"Wed", "Wednesdays"},
                {"Thu", "Thursdays"}, {"Fri", "Fridays"}, {"Sat", "Saturdays"}, {"Sun", "Sundays"}
            };

            insightsText = $"You write most on <strong>{fullDayNames[bestDay.ShortName]}</strong>";
            
            if (happiestDay.ShortName == bestDay.ShortName)
            {
                insightsText += $" — and it's also your happiest day {happiestDay.MoodEmoji}";
            }
            else
            {
                insightsText += $". Your happiest day is <strong>{fullDayNames[happiestDay.ShortName]}</strong> {happiestDay.MoodEmoji}";
            }

            if (leastDay.ShortName != bestDay.ShortName)
            {
                insightsText += $". You write least on <strong>{fullDayNames[leastDay.ShortName]}</strong>.";
            }
        }
    }

    private static string GetMoodEmoji(double score)
    {
        if (score < 1.5) return "😭";
        if (score < 2.5) return "😕";
        if (score < 3.5) return "😐";
        if (score < 4.5) return "🙂";
        return "✨";
    }

    private static string GetMoodLabel(double score)
    {
        if (score < 1.5) return "Terrible";
        if (score < 2.5) return "Bad";
        if (score < 3.5) return "Okay";
        if (score < 4.5) return "Good";
        return "Amazing";
    }
}

