@inject DiaryService DiaryService
@inject CommunityService CommunityService

<div class="home-stats-wrapper">
<div class="stats-toggle" role="tablist" aria-label="Stats mode">
    <button type="button" class="@StatsButtonClass(StatsMode.Personal)" @onclick="() => SelectMode(StatsMode.Personal)">Personal Stats</button>
    <button type="button" class="@StatsButtonClass(StatsMode.Community)" @onclick="() => SelectMode(StatsMode.Community)">Community Stats</button>
</div>

@if (IsLoading)
{
    <section class="stats-row">
        <div class="stat-card skeleton">
            <div class="streak-icon">
                <div class="fire-wrap">
                    <span class="main-icon">🔥</span>
                    <span class="spark"></span>
                    <span class="spark"></span>
                    <span class="spark"></span>
                </div>
            </div>
            <div class="stat-body">
                <span class="stat-value skeleton-text"></span>
                <span class="stat-label">Day streak</span>
            </div>
        </div>
        <div class="stat-card skeleton">
            <div class="stat-body">
                <span class="stat-value skeleton-text"></span>
                <span class="stat-label">Total entries</span>
            </div>
        </div>
        <div class="stat-card skeleton">
            <div class="stat-body">
                <span class="stat-label">Average Mood</span>
            </div>
        </div>
    </section>
}
else if (mode == StatsMode.Personal)
{
    <section class="stats-row">
        <div class="stat-card">
            <div class="streak-icon">
                <div class="fire-wrap">
                    <span class="main-icon">🔥</span>
                    <span class="spark"></span>
                    <span class="spark"></span>
                    <span class="spark"></span>
                </div>
            </div>
            <div class="stat-body">
                <span class="stat-value">@Streak</span>
                <span class="stat-label">Day streak</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <span class="stat-value">@Total</span>
                <span class="stat-label">Total entries</span>
            </div>
        </div>
        <div class="stat-card">
            <span class="icon-mood">@AvgMood</span>
            <div class="stat-body">
                <span class="stat-label">Avg mood</span>
            </div>
        </div>
    </section>

    @if (dayStats.Any(d => d.Count > 0))
    {
        <section class="mood-chart-section">
            <div class="wdc-card">
                <div class="wdc-header">
                    <span class="wdc-title">BEST WRITING DAYS</span>
                    <span class="wdc-subtitle">entries per day of week</span>
                </div>

                <div class="wdc-chart">
                    @foreach (var day in dayStats.Select((d, i) => new { Day = d, Index = i + 1 }))
                    {
                        <div class="wdc-col col-@day.Index @(day.Day.IsToday ? "wdc-today" : "")">
                            <div class="wdc-bar-wrap">
                                <span class="wdc-count">@day.Day.Count</span>
                                <div class="wdc-bar-track">
                                    <div class="wdc-bar-fill"
                                         style="height: @(day.Day.HeightPercent)%; background: @day.Day.BarColor;">
                                    </div>
                                </div>
                            </div>

                            <div class="wdc-mood mood-@day.Index" title="Avg mood: @day.Day.AvgMoodLabel">
                                @day.Day.MoodEmoji
                            </div>

                            <div class="wdc-label">@day.Day.ShortName</div>

                            @if (day.Day.IsBest)
                            {
                                <div class="wdc-best-tag">best</div>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(insightsText))
                {
                    <div class="wdc-insights">
                        <p>@((MarkupString)insightsText)</p>
                    </div>
                }

                <div class="wdc-legend">
                    <div class="wdc-legend-item">
                        <span class="wdc-legend-dot" style="background: #2d5a3d;"></span>
                        <span>More entries</span>
                    </div>
                    <div class="wdc-legend-item">
                        <span class="wdc-legend-dot" style="background: #c8e6d4;"></span>
                        <span>Fewer entries</span>
                    </div>
                    <div class="wdc-legend-item">
                        <span>emoji = Average Mood That Day</span>
                    </div>
                </div>
            </div>
        </section>
    }
}
else if (mode == StatsMode.Community)
{
    <div class="community-header">
        <div class="time-filters">
            <button class="filter-pill @(ActiveCommunityFilter == "today" ? "active" : "")"
                    @onclick='() => SetCommunityFilter("today")'>Today</button>
            <button class="filter-pill @(ActiveCommunityFilter == "week" ? "active" : "")"
                    @onclick='() => SetCommunityFilter("week")'>This week</button>
            <button class="filter-pill @(ActiveCommunityFilter == "month" ? "active" : "")"
                    @onclick='() => SetCommunityFilter("month")'>This month</button>
        </div>
    </div>

    @if (communityStats != null)
    {
        <div class="community-grid">
            <!-- Left Column: Community Mood -->
            <div class="community-card mood-panel">
                <div class="card-header-label">COMMUNITY MOOD @ActiveCommunityFilter.ToUpper()</div>

                <div class="dominant-mood-hero">
                    <span class="dominant-emoji">@GetMoodEmoji(communityStats.DominantMood)</span>
                    <div class="dominant-info">
                        <h3>@Capitalize(communityStats.DominantMood)</h3>
                        <p>Dominant mood across @communityStats.TotalEntriesToday entries @(ActiveCommunityFilter == "today" ? "today" : "this " + ActiveCommunityFilter.Replace("week", "week").Replace("month", "month"))</p>
                    </div>
                </div>

                <div class="mood-dist-list">
                    @foreach (var mood in MoodsDescending)
                    {
                        var count = communityStats.MoodCounts.GetValueOrDefault(mood, 0);
                        var pct = communityStats.TotalEntriesToday > 0
                            ? (int)Math.Round((double)count / communityStats.TotalEntriesToday * 100)
                            : 0;
                        <div class="mood-dist-row">
                            <span class="mood-dist-emoji">@GetMoodEmoji(mood)</span>
                            <div class="mood-dist-track">
                                <div class="mood-dist-fill mood-fill-@mood" style="width: @pct%"></div>
                            </div>
                            <span class="mood-dist-pct">@pct%</span>
                        </div>
                    }
                </div>

                <div class="quick-stats-grid">
                    <div class="qs-item">
                        <span class="qs-val">@communityStats.TotalEntriesToday</span>
                        <span class="qs-label">entries @ActiveCommunityFilter</span>
                    </div>
                    <div class="qs-item">
                        <span class="qs-val">@communityStats.ActiveUsersToday</span>
                        <span class="qs-label">active users</span>
                    </div>
                    <div class="qs-item">
                        <span class="qs-val">@communityStats.AvgCommunityScore.ToString("F1")</span>
                        <span class="qs-label">avg score</span>
                    </div>
                </div>
            </div>

            <!-- Right Column: Mood Leaderboard -->
            <div class="community-card leaderboard-panel">
                <div class="leaderboard-header">
                    <div class="card-header-label">MOOD LEADERBOARD</div>
                    <div class="toggle-group">
                        <button class="toggle-btn @(LeaderboardSort == "score" ? "active" : "")" 
                                @onclick='() => SetLeaderboardSort("score")'>Score</button>
                        <button class="toggle-btn @(LeaderboardSort == "streak" ? "active" : "")" 
                                @onclick='() => SetLeaderboardSort("streak")'>Streak</button>
                    </div>
                </div>

                @if (leaderboard != null)
                {
                    <div class="leaderboard-list">
                        @for (int i = 0; i < leaderboard.Count; i++)
                        {
                            var entry = leaderboard[i];
                            <div class="leaderboard-row @(entry.IsCurrentUser ? "is-me" : "")">
                                <span class="rank-circle">@(i + 1)</span>
                                <div class="avatar" style="background-color: @entry.AvatarBg; color: @entry.AvatarFg;">
                                    @entry.Initials
                                </div>
                                <div class="user-info">
                                    <span class="user-name">@entry.DisplayName</span>
                                    @if (entry.IsCurrentUser)
                                    {
                                        <span class="me-badge">you</span>
                                    }
                                </div>
                                <div class="user-score">
                                    @if (LeaderboardSort == "score")
                                    {
                                        <span class="score-val">@entry.AvgMoodScore.ToString("F1")</span><span class="score-max">/5</span>
                                    }
                                    else
                                    {
                                        <span class="score-val">@entry.Streak</span><span class="score-max">d</span>
                                    }
                                    <span class="user-mood">@GetMoodEmoji(entry.AvgMoodScore)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="leaderboard-loading">Loading...</div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="community-loading">
            <p>Loading community stats...</p>
        </div>
    }
}

@code {
    private enum StatsMode { Personal, Community }
    private StatsMode mode = StatsMode.Personal;

    private bool IsLoading = true;
    private int Streak;
    private int Total;
    private string AvgMood = "🙂";

    private List<DayStat> dayStats = new();
    private string insightsText = "";

    private CommunityStats? communityStats;
    private List<LeaderboardEntry>? leaderboard;
    private string ActiveCommunityFilter = "today";
    private string LeaderboardSort = "score";
    private static readonly string[] MoodsDescending = { "amazing", "good", "okay", "bad", "terrible" };

    private string StatsButtonClass(StatsMode m) => m == mode ? "stats-toggle-btn-active" : "";

    private void SelectMode(StatsMode m)
    {
        mode = m;
        if (mode == StatsMode.Community && communityStats == null)
        {
            _ = LoadCommunityStatsAsync();
        }
        StateHasChanged();
    }

    private async Task LoadCommunityStatsAsync()
    {
        communityStats = await CommunityService.GetCommunityStatsAsync(ActiveCommunityFilter);
        leaderboard = await CommunityService.GetLeaderboardAsync(ActiveCommunityFilter, LeaderboardSort);
        StateHasChanged();
    }

    private async Task SetCommunityFilter(string filter)
    {
        ActiveCommunityFilter = filter;
        await LoadCommunityStatsAsync();
    }

    private async Task SetLeaderboardSort(string sort)
    {
        LeaderboardSort = sort;
        leaderboard = await CommunityService.GetLeaderboardAsync(ActiveCommunityFilter, LeaderboardSort);
        StateHasChanged();
    }

    private record DayStat(
        string ShortName,
        int Count,
        double AvgMoodScore,
        string MoodEmoji,
        string AvgMoodLabel,
        double HeightPercent,
        string BarColor,
        bool IsBest,
        bool IsToday
    );

    protected override async Task OnInitializedAsync()
    {
        var entries = await DiaryService.GetEntriesAsync();
        var sorted = entries.OrderByDescending(e => e.Date).ToList();
        Total = sorted.Count;
        Streak = CalculateStreak(sorted);
        AvgMood = CalculateAvgMood(sorted);
        BuildWritingStats(sorted);
        IsLoading = false;
    }

    private static int CalculateStreak(List<DiaryEntry> sorted)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var streak = 0;
        var expected = today;
        foreach (var e in sorted)
        {
            var d = DateOnly.FromDateTime(e.Date);
            if (d == expected) { streak++; expected = expected.AddDays(-1); }
            else if (d < expected) break;
        }
        return streak;
    }

    private static string CalculateAvgMood(List<DiaryEntry> entries)
    {
        var scores = entries.Where(e => !string.IsNullOrEmpty(e.Mood)).Select(e => MoodValue(e.Mood)).ToList();
        if (!scores.Any()) return "🙂";
        var avg = scores.Average();
        if (avg < 1.5) return "😭";
        if (avg < 2.5) return "😕";
        if (avg < 3.5) return "😐";
        if (avg < 4.5) return "🙂";
        return "✨";
    }

    private static double MoodValue(string mood) => mood.ToLower() switch
    {
        "terrible" => 1,
        "bad"      => 2,
        "okay"     => 3,
        "good"     => 4,
        "amazing"  => 5,
        _          => 3
    };

    private void BuildWritingStats(List<DiaryEntry> entries)
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var dotNetDays = new[]
        {
            DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
            DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
        };
        var todayDow = DateTime.Today.DayOfWeek;

        var grouped = entries
            .GroupBy(e => e.Date.DayOfWeek)
            .ToDictionary(g => g.Key, g => g.ToList());

        var counts = dotNetDays.Select(d => grouped.ContainsKey(d) ? grouped[d].Count : 0).ToList();
        int maxCount = counts.Max() == 0 ? 1 : counts.Max();
        int bestIndex = counts.IndexOf(counts.Max());

        var colorStops = new[] { "#c8e6d4", "#9aced4", "#6ab8a0", "#3d9970", "#2d5a3d" };

        dayStats = dotNetDays.Select((dow, i) =>
        {
            var entriesForDay = grouped.ContainsKey(dow) ? grouped[dow] : new List<DiaryEntry>();
            int count = entriesForDay.Count;
            double heightPct = maxCount > 0 ? Math.Max(4, (count / (double)maxCount) * 110) : 4;

            double avgScore = entriesForDay
                .Where(e => !string.IsNullOrEmpty(e.Mood))
                .Select(e => MoodValue(e.Mood))
                .DefaultIfEmpty(3)
                .Average();

            int colorIndex = count == 0 ? 0 : (int)Math.Round((count / (double)maxCount) * 4);
            colorIndex = Math.Clamp(colorIndex, 0, 4);

            return new DayStat(
                ShortName: days[i],
                Count: count,
                AvgMoodScore: avgScore,
                MoodEmoji: GetMoodEmoji(avgScore),
                AvgMoodLabel: GetMoodLabel(avgScore),
                HeightPercent: heightPct,
                BarColor: colorStops[colorIndex],
                IsBest: i == bestIndex && count > 0,
                IsToday: dow == todayDow
            );
        }).ToList();

        if (dayStats.Any(d => d.Count > 0))
        {
            var bestDay = dayStats[bestIndex];
            var happiestDay = dayStats.OrderByDescending(d => d.AvgMoodScore).First(d => d.Count > 0);
            var leastDay = dayStats.Where(d => d.Count > 0).OrderBy(d => d.Count).First();

            var fullDayNames = new Dictionary<string, string>
            {
                {"Mon","Mondays"},{"Tue","Tuesdays"},{"Wed","Wednesdays"},
                {"Thu","Thursdays"},{"Fri","Fridays"},{"Sat","Saturdays"},{"Sun","Sundays"}
            };

            insightsText = $"You write most on <strong>{fullDayNames[bestDay.ShortName]}</strong>";

            if (happiestDay.ShortName == bestDay.ShortName)
                insightsText += $" — and it's also your happiest day {happiestDay.MoodEmoji}";
            else
                insightsText += $". Your happiest day is <strong>{fullDayNames[happiestDay.ShortName]}</strong> {happiestDay.MoodEmoji}";

            if (leastDay.ShortName != bestDay.ShortName)
                insightsText += $". You write least on <strong>{fullDayNames[leastDay.ShortName]}</strong>.";
        }
    }

    private static string GetMoodEmoji(double score)
    {
        if (score < 1.5) return "😭";
        if (score < 2.5) return "😕";
        if (score < 3.5) return "😐";
        if (score < 4.5) return "🙂";
        return "✨";
    }

    private static string GetMoodEmoji(string? mood) => (mood ?? "").ToLower() switch
    {
        "terrible" => "😢",
        "bad"      => "😕",
        "okay"     => "😐",
        "good"     => "😊",
        "amazing"  => "✨",
        _          => "😊"
    };

    private static string Capitalize(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..];

    private static string GetMoodLabel(double score)
    {
        if (score < 1.5) return "Terrible";
        if (score < 2.5) return "Bad";
        if (score < 3.5) return "Okay";
        if (score < 4.5) return "Good";
        return "Amazing";
    }
}
</div>
