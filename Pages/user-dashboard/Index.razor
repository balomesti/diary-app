@page "/home"
@inject DiaryService DiaryService

<PageTitle>Diary Me - Home</PageTitle>

<div class="home-page-container">
    <!-- TOP SECTION: Welcome & Actions -->
    <section class="hero-section">
        <div class="hero-content">
            <h1>Welcome to</h1>
            <h1> Diary Me</h1>
            <p>Capture your thoughts, memories, and experiences.</p>
            
            <div class="hero-buttons">
                <NavLink class="btn-outline" href="/diary">View Previous Entries</NavLink>
                <NavLink class="btn-solid" href="/diary/add">Start a New Entry</NavLink>
            </div>
        </div>

        <div class="hero-image-wrapper">
            <!-- High quality video to match the journal aesthetic -->
            <video autoplay muted loop playsinline class="hero-video">
                <source src="images/main2.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </section>

    <!-- BOTTOM SECTION: Recent Entries -->
    <section class="recent-entries">
        <h2>Recent Entries</h2>
        <NavLink class="btn-solid" href="/diary">View All Entries</NavLink>

        <div class="entries-container">
            @if (recentEntries == null)
            {
                <div class="empty-state">
                    <p>Loading your recent thoughts...</p>
                </div>
            }
            else if (!recentEntries.Any())
            {
                <div class="empty-state">
                    <p>No entries yet. Start your journey today!</p>
                </div>
            }
            else
            {
                @foreach (var entry in recentEntries)
                {
                    <NavLink class="entry-card" href="@($"/diary/{entry.Id}")">
                        <div class="entry-image-container">
                            @{
                                var firstUrl = entry.ImageUrls?.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
                            }
                            @if (!string.IsNullOrEmpty(firstUrl))
                            {
                                <img src="@($"http://localhost:5105{firstUrl}")" alt="@entry.Title" class="entry-image">
                            }
                            else
                            {
                                <!-- Textured placeholder if no image exists -->
                                <img src="https://images.unsplash.com/photo-1586075010923-2dd4570fb338?q=80&w=400&auto=format&fit=crop" alt="Entry Texture" class="entry-image">
                            }
                        </div>
                        
                        <div class="entry-text">
                            <h3>@entry.Title</h3>
                            <p>@entry.Content</p>
                        </div>
                    </NavLink>
                }
            }
        </div>
    </section>
</div>

@code {
    private List<DiaryEntry>? recentEntries;

    protected override async Task OnInitializedAsync()
    {
        var allEntries = await DiaryService.GetEntriesAsync();
        recentEntries = allEntries
            .OrderByDescending(e => e.Date)
            .Take(4)
            .ToList();
    }
}
