@page "/home"
@inject DiaryService DiaryService

<PageTitle>Inkly - Home</PageTitle>

<div class="home-page-container">
    <!-- TOP SECTION: Redesigned Hero Section -->
    <section class="hero-section">
        <div class="hero-left">
            <div class="tagline">your personal diary</div>
            <h1 class="title">
                <span class="title-word">Welcome</span>
                <span class="title-word">to</span>
                <span class="inkly-wrap">
                    <span class="inkly-text">Inkly</span>
                </span>
            </h1>
            <p class="subtitle">Capture your thoughts, memories, and experiences one day at a time.</p>
            <div class="btn-row">
                <NavLink class="btn-outline" href="/diary">Previous Entries</NavLink>
                <NavLink class="btn-solid" href="/diary/add">Start New Entry</NavLink>
            </div>
        </div>

        <div class="hero-right">
            <svg class="quill-svg" width="48" height="90" viewBox="0 0 48 90" fill="none">
                <path d="M24 88 C16 60 8 40 2 10 C14 18 28 22 46 8 C38 30 32 54 24 88Z" fill="#D4C9BD" stroke="#b5a898" stroke-width="1" />
                <path d="M24 88 L24 50" stroke="#8B7355" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <div class="ink-drop"></div>
            <div class="ink-drop"></div>
            <div class="ink-drop"></div>
            <p class="hint">Your Memories</p>
            <div class="journal-stack">
                <div class="journal-card">
                    <div class="card-date">@GetDayName(Today.AddDays(-2))</div>
                    <div class="card-line full"></div>
                    <div class="card-line med"></div>
                    <div class="card-line short"></div>
                    <div class="card-tag">🌤 reflective</div>
                </div>
                <div class="journal-card">
                    <div class="card-dot"></div>
                    <div class="card-date">@GetDayName(Today.AddDays(-1))</div>
                    <div class="card-line full"></div>
                    <div class="card-line med"></div>
                    <div class="card-line full accent"></div>
                    <div class="card-tag">✨ grateful</div>
                </div>
                <div class="journal-card" style="position: relative;">
                    <div class="card-dot"></div>
                    <div class="card-date">TODAY</div>
                    <div class="writing-line"></div>
                    <div class="writing-line-2"></div>
                    <div class="cursor-blink"></div>
                    <div class="card-tag">📝 in progress</div>
                </div>
            </div>
        </div>
    </section>

    <!-- STATS & MOOD CHART -->
    <HomeStats />

    <!-- BOTTOM SECTION: Recent Entries -->
    <section class="recent-entries">
        <h2>Recent Entries</h2>
        <NavLink class="btn-solid" href="/diary">View All Entries</NavLink>

        <div class="entries-container">
            @if (recentEntries == null)
            {
                <div class="empty-state">
                    <p>Loading your recent thoughts...</p>
                </div>
            }
            else if (!recentEntries.Any())
            {
                <div class="empty-state">
                    <p>No entries yet. Start your journey today!</p>
                </div>
            }
            else
            {
                @foreach (var entry in recentEntries)
                {
                    <NavLink class="entry-card" href="@($"/diary/{entry.Id}")">
                        <div class="entry-image-container">
                            @{
                                var firstUrl = entry.ImageUrls?.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
                            }
                            @if (!string.IsNullOrEmpty(firstUrl))
                            {
                                <img src="@($"http://localhost:5105{firstUrl}")" alt="@entry.Title" class="entry-image">
                            }
                            else
                            {
                                <div class="card-icon-fallback">
                                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                                    </svg>
                                </div>
                            }
                        </div>

                        <div class="entry-text">
                            <div class="entry-date">@entry.Date.ToString("MMMM d, yyyy")</div>
                            <h3>@entry.Title</h3>

                            @if (!string.IsNullOrEmpty(entry.Location) || !string.IsNullOrEmpty(entry.Weather) || !string.IsNullOrEmpty(entry.Mood))
                            {
                                <div class="context-ribbon">
                                    @if (!string.IsNullOrEmpty(entry.Location))
                                    {
                                        <span class="context-pill">📍 @entry.Location</span>
                                    }
                                    @if (!string.IsNullOrEmpty(entry.Weather))
                                    {
                                        <span class="context-pill">⛅ @entry.Weather</span>
                                    }
                                    @if (!string.IsNullOrEmpty(entry.Mood))
                                    {
                                        <span class="context-pill">@GetMoodEmoji(entry.Mood) @entry.Mood</span>
                                    }
                                </div>
                            }
                        </div>
                    </NavLink>
                }
            }
        </div>
    </section>
</div>

@code {
    private List<DiaryEntry>? recentEntries;
    private DateTime Today => DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var allEntries = await DiaryService.GetEntriesAsync();
        recentEntries = allEntries
            .OrderByDescending(e => e.Date)
            .Take(4)
            .ToList();
    }

    private string GetDayName(DateTime date) => date.ToString("ddd, MMM d").ToUpper();

    private static string GetMoodEmoji(string mood) => mood.ToLower() switch
    {
        "terrible" => "😢",
        "bad" => "😕",
        "okay" => "😐",
        "good" => "😊",
        "amazing" => "✨",
        _ => "😊"
    };
}