@page "/home"
@inject DiaryService DiaryService

<PageTitle>Home</PageTitle>

<section class="home-hero">
    <div class="hero-content">
        <h1>Welcome to Diary Me</h1>
        <p>Capture your thoughts, memories, and experiences.</p>

        <div class="hero-actions">
            <NavLink class="btn-outline" href="/diary">View Previous Entries</NavLink>
            <NavLink class="btn-solid" href="/diary/add">Start a New Entry</NavLink>
        </div>

        <div class="hero-filters">
            <button class="chip">Today</button>
            <button class="chip">This Week</button>
            <button class="chip">This Month</button>
        </div>
    </div>

    <div class="hero-image">
        <img src="/images/pic1.jpg" alt="Beautiful Mountains" />
    </div>
</section>

<section class="recent-section">
    <div class="recent-header">
        <h2>Recent Entries</h2>
        <NavLink class="btn-view-all" href="/diary">View All Entries</NavLink>
    </div>

    @if (recentEntries == null)
    {
        <p>Loading...</p>
    }
    else if (!recentEntries.Any())
    {
        <div class="empty-state">
            <p class="empty-title">No entries yet.</p>
            <NavLink class="btn-solid-diary" href="/diary/add">Create your first entry</NavLink>
        </div>
    }
    else
    {
        <div class="entries-grid">
            @foreach (var entry in recentEntries)
            {
                <div class="entry-card-home">
                    <div class="entry-img-box">
                        @if (!string.IsNullOrEmpty(entry.ImageUrl))
                        {
                            <img src="@($"http://localhost:5105{entry.ImageUrl}")" alt="@entry.Title" />
                        }
                    </div>
                    <div class="entry-info">
                        <h3>@entry.Title</h3>
                        <p>@entry.Content</p>
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    private List<DiaryEntry>? recentEntries;

    protected override async Task OnInitializedAsync()
    {
        var allEntries = await DiaryService.GetEntriesAsync();
        recentEntries = allEntries
            .OrderByDescending(e => e.Date)
            .Take(4)
            .ToList();
    }
}

