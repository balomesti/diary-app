@page "/explore"
@using System.Linq
@inject DiaryService DiaryService
@inject IJSRuntime JS

<PageTitle>Explore</PageTitle>

<section class="explore-hero">
    <h1>Explore</h1>
    <p>Explore news posts from the admin team.</p>
</section>

<section class="explore-feed">
    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="explore-error" role="alert">@loadError</div>
    }
    else if (isLoading)
    {
        <p class="explore-loading">Loading...</p>
    }
    else if (updates.Count == 0)
    {
        <p class="explore-empty">No explore posts found.</p>
    }
    else
    {
        @foreach (var item in updates)
        {
            <article class="explore-post-card">
                <div class="explore-post-author-row">
                    <div class="explore-post-avatar">@GetAvatarInitials(item.Author)</div>
                    <div class="explore-post-author-meta">
                        <span class="explore-post-author-name">@item.Author</span>
                        <span class="explore-post-timestamp">@TimeAgo(item.CreatedAt)</span>
                    </div>
                </div>

                <div class="explore-post-gallery" id="gallery-@item.Id" style="background: @item.GalleryBackgrounds[item.GalleryIndex]">
                    @if (string.IsNullOrWhiteSpace(item.ImageUrl) && string.IsNullOrWhiteSpace(item.VideoUrl))
                    {
                        <div class="explore-post-gallery-placeholder">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                    {
                        <video class="explore-post-video" controls>
                            <source src="@item.VideoUrl" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    }
                    else
                    {
                        @foreach (var (url, index) in item.ImageUrls.Select((u, i) => (u, i)))
                        {
                            <img class="explore-post-gallery-img @(index == item.GalleryIndex ? "active" : "")" 
                                 src="@url" 
                                 alt="@item.Title" />
                        }
                    }

                    @if (item.ImageUrls.Count > 1)
                    {
                        <span class="explore-post-gallery-count">@(item.GalleryIndex + 1) / @item.ImageUrls.Count</span>
                        <div class="explore-post-gallery-dots">
                            @for (int i = 0; i < item.ImageUrls.Count; i++)
                            {
                                var index = i;
                                <div class="explore-post-gallery-dot @(index == item.GalleryIndex ? "active" : "")" @onclick="() => SetSlide(item, index)"></div>
                            }
                        </div>
                        <button class="explore-post-gallery-nav prev" @onclick="() => PrevSlide(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
                        </button>
                        <button class="explore-post-gallery-nav next" @onclick="() => NextSlide(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
                        </button>
                    }
                </div>

                <div class="explore-post-body">
                    <h2 class="explore-post-title">@item.Title</h2>
                    <p class="explore-post-caption @(item.IsExpanded ? "" : "clamped")" id="cap-@item.Id">@item.Description</p>
                    @if (item.NeedsReadMore)
                    {
                        <button class="explore-post-read-more" id="rmb-@item.Id" @onclick="() => ToggleReadMore(item)">
                            @(item.IsExpanded ? "Show less" : "Read more")
                        </button>
                    }
                </div>

                <div class="reaction-bar">
                    <button class="reaction-btn heart @(item.Reacted.Contains("heart") ? "reacted heart" : "")" @onclick='() => ToggleReaction(item, "heart")'>
                        <span class="reaction-emoji">❤️</span><span class="reaction-count">@item.ReactionCounts.GetValueOrDefault("heart")</span>
                    </button>
                    <button class="reaction-btn fire @(item.Reacted.Contains("fire") ? "reacted fire" : "")" @onclick='() => ToggleReaction(item, "fire")'>
                        <span class="reaction-emoji">🔥</span><span class="reaction-count">@item.ReactionCounts.GetValueOrDefault("fire")</span>
                    </button>
                    <button class="reaction-btn bulb @(item.Reacted.Contains("bulb") ? "reacted bulb" : "")" @onclick='() => ToggleReaction(item, "bulb")'>
                        <span class="reaction-emoji">💡</span><span class="reaction-count">@item.ReactionCounts.GetValueOrDefault("bulb")</span>
                    </button>
                    <button class="reaction-btn clap @(item.Reacted.Contains("clap") ? "reacted clap" : "")" @onclick='() => ToggleReaction(item, "clap")'>
                        <span class="reaction-emoji">👏</span><span class="reaction-count">@item.ReactionCounts.GetValueOrDefault("clap")</span>
                    </button>
                    <div class="action-right">
                        <button class="icon-btn @(item.ShowComments ? "active" : "")" @onclick="() => ToggleComments(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span>@item.Comments.Count</span>
                        </button>
                        <button class="icon-btn" @onclick="() => HandleShare(item, item.Title)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        </button>
                    </div>
                </div>

                @if (item.ShowComments)
                {
                    <div class="comments-section">
                        <hr class="divider" />
                        <div class="comments-list">
                            @foreach (var (c, idx) in item.Comments.Select((c, i) => (c, i)))
                            {
                                if (idx < item.VisibleComments)
                                {
                                    <div class="comment-row">
                                        <div class="comment-avatar" style="background:#dbeafe;color:#1e40af">@GetAvatarInitials(c.Author)</div>
                                        <div class="comment-bubble">
                                            <div class="comment-author">@c.Author</div>
                                            <div class="comment-text">@c.Text</div>
                                            <div class="comment-meta">
                                                <span class="comment-time">@TimeAgo(c.CreatedAt)</span>
                                                <button class="comment-like-btn @(c.Liked ? "liked" : "")" @onclick="() => ToggleCommentLike(c)">♥ @(c.Liked ? "Liked" : "Like")</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        @if (item.Comments.Count > item.VisibleComments)
                        {
                            <button class="show-more-btn" @onclick="() => ShowMoreComments(item)">View more comments</button>
                        }
                        <div class="comment-input-row">
                            <div class="comment-input-avatar">Me</div>
                            <div class="comment-input-wrap">
                                <input placeholder="Write a comment…" @bind="item.NewCommentText" />
                                <button class="comment-send-btn" disabled="@string.IsNullOrWhiteSpace(item.NewCommentText)" @onclick="() => AddComment(item)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </article>
        }
    }
</section>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<UpdateItem> updates = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostDto>("api/Admin/news");

            updates = items
                .Select(n => new UpdateItem
                {
                    Id = n.Id,
                    Kind = "Explore",
                    Title = n.Title,
                    Description = n.Content,
                    Author = n.Author,
                    CreatedAt = n.CreatedAt,
                    ImageUrl = n.ImageUrl,
                    VideoUrl = n.VideoUrl,
                    ImageUrls = string.IsNullOrWhiteSpace(n.ImageUrl) ? new List<string>() : new List<string> { n.ImageUrl },
                    NeedsReadMore = n.Content.Length > 280
                })
                .OrderByDescending(x => x.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static readonly string[] GalleryBackgrounds = { "#b5c4b1", "#c4b5b5", "#b5b9c4" };

    private static string TimeAgo(DateTime date)
    {
        var diff = Math.Floor((DateTime.Now - date).TotalSeconds);
        if (diff < 60) return "just now";
        if (diff < 3600) return Math.Floor(diff / 60) + "m ago";
        if (diff < 86400) return Math.Floor(diff / 3600) + "h ago";
        if (diff < 604800) return Math.Floor(diff / 86400) + "d ago";
        return date.ToString("MMM d");
    }

    private static string GetAvatarInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return (parts[0][0] + "" + parts[1][0]).ToUpper();
        return parts[0][0].ToString().ToUpper();
    }

    private void SetSlide(UpdateItem item, int index)
    {
        item.GalleryIndex = index;
    }

    private void PrevSlide(UpdateItem item)
    {
        item.GalleryIndex = (item.GalleryIndex - 1 + item.ImageUrls.Count) % item.ImageUrls.Count;
    }

    private void NextSlide(UpdateItem item)
    {
        item.GalleryIndex = (item.GalleryIndex + 1) % item.ImageUrls.Count;
    }

    private void ToggleReadMore(UpdateItem item)
    {
        item.IsExpanded = !item.IsExpanded;
    }

    private void ToggleComments(UpdateItem item)
    {
        item.ShowComments = !item.ShowComments;
    }

    private void ShowMoreComments(UpdateItem item)
    {
        item.VisibleComments = Math.Min(item.VisibleComments + 2, item.Comments.Count);
    }

    private void ToggleReaction(UpdateItem item, string key)
    {
        if (item.Reacted.Contains(key))
        {
            item.Reacted.Remove(key);
            item.ReactionCounts[key] = Math.Max(0, item.ReactionCounts.GetValueOrDefault(key) - 1);
        }
        else
        {
            item.Reacted.Add(key);
            item.ReactionCounts[key] = item.ReactionCounts.GetValueOrDefault(key) + 1;
        }
    }

    private void ToggleCommentLike(CommentItem c)
    {
        c.Liked = !c.Liked;
    }

    private void AddComment(UpdateItem item)
    {
        var text = item.NewCommentText?.Trim();
        if (string.IsNullOrEmpty(text)) return;
        item.Comments.Add(new CommentItem { Author = "You", Text = text, CreatedAt = DateTime.Now });
        item.NewCommentText = string.Empty;
    }

    private async Task HandleShare(UpdateItem item, string title)
    {
        var text = "Check out: " + title;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private sealed class UpdateItem
    {
        public int Id { get; set; }
        public string Kind { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public List<string> ImageUrls { get; set; } = new();
        public int GalleryIndex { get; set; }
        public bool IsExpanded { get; set; }
        public bool NeedsReadMore { get; set; }
        public string[] GalleryBackgrounds => Explore.GalleryBackgrounds;
        public bool ShowComments { get; set; }
        public int VisibleComments { get; set; } = 2;
        public string NewCommentText { get; set; } = "";
        public List<CommentItem> Comments { get; set; } = new();
        public Dictionary<string, int> ReactionCounts { get; set; } = new() { { "heart", 0 }, { "fire", 0 }, { "bulb", 0 }, { "clap", 0 } };
        public List<string> Reacted { get; set; } = new();
    }

    private sealed class CommentItem
    {
        public string Author { get; set; } = "";
        public string Text { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public bool Liked { get; set; }
    }

    private sealed class NewsPostDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
