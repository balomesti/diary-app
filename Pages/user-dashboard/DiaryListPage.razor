@page "/diary"
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Diary Me - My Diary</PageTitle>

<div class="diary-list-page">
    <!-- Hero Section -->
    <section class="hero">
        <h1>My Diary</h1>
        <p>Capture your moments and reflections.</p>
        <div class="hero-buttons">
            <NavLink class="btn-solid" href="/diary/add">New Entry</NavLink>
        </div>
    </section>

    <!-- Gamification Section -->
    <section class="gamification-section">
        <div class="gamification-row">
            <!-- Streak Card -->
            <div class="stat-card streak-card">
                <div class="streak-icon">
                    <div class="fire-wrap">
                        <span class="fire-icon">🔥</span>
                        <span class="spark"></span>
                        <span class="spark"></span>
                        <span class="spark"></span>
                    </div>
                </div>
                <div class="stat-info">
                    <h3>@streakCount Day Streak</h3>
                    <p>@(streakCount > 0 ? "You're on fire! Keep it up." : "Start your streak today!")</p>
                </div>
            </div>

            <!-- Progress Card -->
            <div class="stat-card progress-card">
                <div class="stat-info">
                    <div class="progress-header">
                        <h3>Total Entries: @totalEntries</h3>
                        <span class="next-milestone">Next: @nextMilestone</span>
                    </div>
                    <div class="progress-container">
                        <div class="progress-fill" style="width: @GetProgressPercentage()%"></div>
                    </div>
                    <p class="progress-hint">@GetEntriesToNextMilestone() more to become a <b>@GetNextMilestoneTitle()</b></p>
                </div>
            </div>
        </div>

        <!-- Milestones Card -->
        <div class="milestones-card">
            <div class="milestone-header">
                <h3>Achievements</h3>
            </div>
            <AnimatedBadges Badges="badges" />
        </div>
    </section>

    <!-- Entries List Section -->
    <section class="entries-section">
        <div class="entries-header">
            <h2>List of Entries</h2>
            <p>View all your diary entries.</p>
        </div>

        <div class="entries-grid">
            @if (entries == null)
            {
                <div class="empty-state">
                    <p>Loading your precious memories...</p>
                </div>
            }
            else if (!entries.Any())
            {
                <div class="empty-state">
                    <h2 class="empty-title">No entries yet.</h2>
                    <p>Every journey starts with a single word.</p>
                    <NavLink class="btn-solid" href="/diary/add" style="margin-top: 20px;">Add your first entry</NavLink>
                </div>
            }
            else
            {
                @foreach (var entry in entries.OrderByDescending(e => e.Date))
                {
                    <div class="diary-card" @onclick="() => ViewDetail(entry.Id)">
                        <!-- Card Image Section -->
                        <div class="card-image-container">
                            @if (!string.IsNullOrEmpty(entry.ImageUrls))
                            {
                                var firstImageUrl = entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
                                if (!string.IsNullOrEmpty(firstImageUrl))
                                {
                                    <img src="@($"http://localhost:5105{firstImageUrl}")" alt="@entry.Title" class="card-image" />
                                    if (entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries).Length > 1)
                                    {
                                        <div class="image-count-badge">
                                            +@(entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries).Length - 1)
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="card-icon-fallback">
                                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                                        </svg>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="card-icon-fallback">
                                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                                    </svg>
                                </div>
                            }
                        </div>

                        <div class="card-content">
                            <h3>@entry.Title</h3>
                            <p>@entry.Content</p>

                            <hr class="card-divider">

                            <div class="card-footer">
                                <span class="card-date">@entry.Date.ToString("MMMM d, yyyy")</span>
                                <div class="card-actions">
                                    <button class="action-btn btn-edit" type="button" @onclick:stopPropagation="true" @onclick="() => EditEntry(entry)">Edit</button>
                                    <button class="action-btn btn-delete" type="button" @onclick:stopPropagation="true" @onclick="() => DeleteEntry(entry)">Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

@code {
    private List<DiaryEntry>? entries;

    private int totalEntries = 33;
    private int streakCount = 7;
    private int nextMilestone = 50;

    private List<Badge> badges = new List<Badge>
    {
        new Badge { IconClass = "fas fa-seedling", Title = "First Entry", IsUnlocked = false },
        new Badge { IconClass = "fas fa-calendar-check", Title = "7 Days", IsUnlocked = false },
        new Badge { IconClass = "fas fa-camera", Title = "Photo Buff", IsUnlocked = false },
        new Badge { IconClass = "fas fa-award", Title = "10 Entries", IsUnlocked = false },
        new Badge { IconClass = "fas fa-pen-fancy", Title = "20 Entries", IsUnlocked = false },
        new Badge { IconClass = "fas fa-star", Title = "35 Entries", IsUnlocked = false }
    };

    protected override async Task OnInitializedAsync()
    {
        entries = await DiaryService.GetEntriesAsync();
        if (entries != null)
        {
            totalEntries = entries.Count;
        }
        CalculateNextMilestone();
        UpdateBadgeStatus();

        var streakInfo = await DiaryService.GetStreakAsync();
        if (streakInfo != null)
        {
            streakCount = streakInfo.CurrentStreak;
        }
        UpdateBadgeStatus();
    }

    private void UpdateBadgeStatus()
    {
        foreach (var badge in badges)
        {
            switch (badge.Title)
            {
                case "First Entry":
                    badge.IsUnlocked = totalEntries >= 1;
                    break;
                case "7 Days":
                    badge.IsUnlocked = streakCount >= 7;
                    break;
                case "Photo Buff":
                    badge.IsUnlocked = entries?.Any(e => !string.IsNullOrEmpty(e.ImageUrls)) ?? false;
                    break;
                case "10 Entries":
                    badge.IsUnlocked = totalEntries >= 10;
                    break;
                case "20 Entries":
                    badge.IsUnlocked = totalEntries >= 20;
                    break;
                case "35 Entries":
                    badge.IsUnlocked = totalEntries >= 35;
                    break;
            }
        }
    }

    private void CalculateNextMilestone()
    {
        if (totalEntries >= 35)
            nextMilestone = 35;
        else if (totalEntries >= 20)
            nextMilestone = 35;
        else if (totalEntries >= 10)
            nextMilestone = 20;
        else if (totalEntries >= 5)
            nextMilestone = 10;
        else
            nextMilestone = 5;
    }

    private string GetProgressPercentage()
    {
        int currentMilestone = nextMilestone switch
        {
            35 when totalEntries >= 20 => 20,
            20 when totalEntries >= 10 => 10,
            10 when totalEntries >= 5 => 5,
            5 => 0,
            _ => 0
        };

        if (nextMilestone == 35 && totalEntries >= 20)
            currentMilestone = 20;
        else if (nextMilestone == 20 && totalEntries >= 10)
            currentMilestone = 10;

        double percentage = (double)totalEntries / nextMilestone * 100;
        return Math.Min(percentage, 100).ToString("F0");
    }

    private string GetEntriesToNextMilestone()
    {
        return Math.Max(nextMilestone - totalEntries, 0).ToString();
    }

    private string GetNextMilestoneTitle()
    {
        return nextMilestone switch
        {
            5 => "Beginner",
            10 => "Chronicler",
            20 => "Expert",
            35 => "Legend",
            _ => "Beginner"
        };
    }
    private async Task DeleteEntry(DiaryEntry entry)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Delete \"{entry.Title}\"?");
        if (!confirmed)
        {
            return;
        }

        await DiaryService.DeleteEntryAsync(entry);
        entries = await DiaryService.GetEntriesAsync();
        if (entries != null)
        {
            totalEntries = entries.Count;
            CalculateNextMilestone();
        }
        UpdateBadgeStatus();
    }

    private void EditEntry(DiaryEntry entry)
    {
        NavigationManager.NavigateTo($"/diary/edit/{entry.Id}");
    }

    private void ViewDetail(int id)
    {
        NavigationManager.NavigateTo($"/diary/{id}");
    }
}
