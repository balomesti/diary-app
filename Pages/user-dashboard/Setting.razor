@page "/setting"
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject UserService UserService

<PageTitle>Settings - Diary Me</PageTitle>

<div class="settings-page-container">
    <div class="settings-wrapper">
        <div class="settings-header">
            <h1>Settings</h1>
            <p>Customize your diary experience and manage your account.</p>
        </div>

        <div class="settings-tabs" role="tablist">
            <button type="button" class="settings-tab-btn @GetTabClass(SettingsTab.Profile)" @onclick="() => SelectTab(SettingsTab.Profile)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                Profile
            </button>
            <button type="button" class="settings-tab-btn @GetTabClass(SettingsTab.General)" @onclick="() => SelectTab(SettingsTab.General)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                General
            </button>
            <button type="button" class="settings-tab-btn @GetTabClass(SettingsTab.Privacy)" @onclick="() => SelectTab(SettingsTab.Privacy)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Privacy
            </button>
            <button type="button" class="settings-tab-btn @GetTabClass(SettingsTab.Notifications)" @onclick="() => SelectTab(SettingsTab.Notifications)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                Notifications
            </button>
        </div>

        <div class="settings-card">
            <div class="settings-card-header">
                <h2>@SectionTitle</h2>
                <p>@SectionSubtitle</p>
            </div>

            <div class="settings-card-body">
                @if (activeTab == SettingsTab.Profile)
                {
                    <div class="profile-avatar-section">
                        <div class="avatar-preview-wrapper" @onclick="TriggerImageUpload">
                            @if (!string.IsNullOrEmpty(profileImageUrl))
                            {
                                <img src="@profileImageUrl" alt="Profile" class="avatar-preview-img">
                            }
                            else
                            {
                                <div class="avatar-preview-placeholder">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                </div>
                            }
                            <div class="avatar-overlay">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                            </div>
                        </div>
                        <div class="avatar-info">
                            <h3>Profile Picture</h3>
                            <p>PNG, JPG or GIF. Recommended size 200x200.</p>
                            <div class="avatar-actions">
                                <InputFile id="imageUpload" OnChange="HandleImageUpload" accept="image/*" style="display: none;" />
                                <button type="button" class="btn-change-photo" @onclick="TriggerImageUpload">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                                    Change Photo
                                </button>
                                @if (!string.IsNullOrEmpty(profileImageUrl))
                                {
                                    <button type="button" class="btn-remove-photo" @onclick="RemovePhoto">
                                        Remove
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">Personal Information</h3>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Full Name</label>
                                <input type="text" @bind="profileName" placeholder="Enter your full name">
                            </div>
                            <div class="form-field">
                                <label>Email Address</label>
                                <input type="email" value="@profileEmail" readonly>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">About You</h3>
                        <div class="form-row">
                            <div class="form-field full-width">
                                <label>Bio</label>
                                <textarea @bind="profileBio" placeholder="Write a short bio about yourself..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="settings-actions">
                        <button type="button" class="btn-cancel" @onclick="Cancel">Cancel</button>
                        <button type="button" class="btn-save" @onclick="SaveChanges">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            Save Changes
                        </button>
                    </div>
                }
                else if (activeTab == SettingsTab.General)
                {
                    <div class="form-section">
                        <h3 class="form-section-title">App Settings</h3>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Diary Title</label>
                                <input type="text" @bind="diaryTitle" placeholder="Enter your diary title">
                            </div>
                            <div class="form-field">
                                <label>Font Size</label>
                                <div class="segmented-control">
                                    <button type="button" class="segment-btn @GetSegmentClass(fontSize == "Small")" @onclick='() => SetFontSize("Small")'>Small</button>
                                    <button type="button" class="segment-btn @GetSegmentClass(fontSize == "Medium")" @onclick='() => SetFontSize("Medium")'>Medium</button>
                                    <button type="button" class="segment-btn @GetSegmentClass(fontSize == "Large")" @onclick='() => SetFontSize("Large")'>Large</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="settings-actions">
                        <button type="button" class="btn-cancel" @onclick="Cancel">Cancel</button>
                        <button type="button" class="btn-save" @onclick="SaveChanges">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            Save Changes
                        </button>
                    </div>
                }
                else if (activeTab == SettingsTab.Privacy)
                {
                    <div class="settings-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                        <h3>Privacy Settings</h3>
                        <p>Privacy settings will be available soon.</p>
                    </div>
                }
                else if (activeTab == SettingsTab.Notifications)
                {
                    <div class="settings-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        <h3>Notification Settings</h3>
                        <p>Notification preferences will be available soon.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (showToast)
{
    <div class="toast @toastType">
        @if (toastType == "success")
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        }
        <span>@toastMessage</span>
    </div>
}

@code {
    private enum SettingsTab
    {
        Profile,
        General,
        Privacy,
        Notifications
    }

    private SettingsTab activeTab = SettingsTab.Profile;
    
    private string profileName = "Maria";
    private string profileEmail = "maria@example.com";
    private string profileBio = "Just a girl navigating through life one journal entry at a time.";
    private string profileImageUrl = "";

    private string diaryTitle = "";
    private string fontSize = "Medium";
    private const string FontSizeKey = "diary_font_size";
    private bool showToast;
    private string toastMessage = "";
    private string toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
        await LoadSettingsAsync();
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            var profile = await UserService.GetProfileAsync();
            if (profile != null)
            {
                profileName = profile.Username;
                profileEmail = profile.Email;
                profileBio = profile.UserBio ?? string.Empty;
                if (!string.IsNullOrEmpty(profile.ProfileImg))
                {
                    profileImageUrl = profile.ProfileImg;
                }
            }
        }
        catch
        {
        }
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var savedFontSize = await JS.InvokeAsync<string>("localStorage.getItem", FontSizeKey);
            if (!string.IsNullOrEmpty(savedFontSize))
            {
                fontSize = savedFontSize;
                await ApplyFontSizeAsync(fontSize);
            }
        }
        catch
        {
            fontSize = "Medium";
        }
    }

    private async Task SetFontSize(string size)
    {
        fontSize = size;
        await ApplyFontSizeAsync(size);
        StateHasChanged();
    }

    private async Task ApplyFontSizeAsync(string size)
    {
        var fontSizeVar = size switch
        {
            "Small" => "var(--font-size-small)",
            "Medium" => "var(--font-size-medium)",
            "Large" => "var(--font-size-large)",
            _ => "var(--font-size-medium)"
        };

        await JS.InvokeVoidAsync("eval", $@"
            document.documentElement.style.setProperty('--font-size-base', '{fontSizeVar}');
        ");
    }

    private string SectionTitle => activeTab switch
    {
        SettingsTab.Profile => "Profile Settings",
        SettingsTab.General => "General Settings",
        SettingsTab.Privacy => "Privacy Settings",
        SettingsTab.Notifications => "Notification Settings",
        _ => "Settings"
    };

    private string SectionSubtitle => activeTab switch
    {
        SettingsTab.Profile => "Update your personal information and profile picture.",
        SettingsTab.General => "Customize your diary appearance and preferences.",
        SettingsTab.Privacy => "Control your privacy and visibility settings.",
        SettingsTab.Notifications => "Manage your notification preferences.",
        _ => ""
    };

    private void SelectTab(SettingsTab tab)
    {
        activeTab = tab;
    }

    private string GetTabClass(SettingsTab tab)
    {
        return tab == activeTab ? "active" : "";
    }

    private string GetSegmentClass(bool isActive)
    {
        return isActive ? "active" : "";
    }

    private async Task SaveChanges()
    {
        if (activeTab == SettingsTab.Profile)
        {
            var request = new UpdateProfileRequest
            {
                Username = profileName,
                ProfileImg = profileImageUrl,
                UserBio = profileBio
            };
            var success = await UserService.UpdateProfileAsync(request);
            await ShowToast(success ? "Profile updated successfully!" : "Failed to update profile.", success ? "success" : "error");
        }
        else if (activeTab == SettingsTab.General)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", FontSizeKey, fontSize);
            await ShowToast("Settings saved successfully!", "success");
        }
    }

    private async Task ShowToast(string message, string type)
    {
        toastMessage = message;
        toastType = type;
        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }

    private async Task RemovePhoto()
    {
        profileImageUrl = "";
        var request = new UpdateProfileRequest
        {
            ProfileImg = profileImageUrl
        };
        var success = await UserService.UpdateProfileAsync(request);
        await ShowToast(success ? "Profile photo removed." : "Failed to remove photo.", success ? "success" : "error");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/home");
    }

    private async Task TriggerImageUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('imageUpload').click()");
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var format = "image/jpeg";
            var resizedFile = await file.RequestImageFileAsync(format, 200, 200);
            var buffer = new byte[resizedFile.Size];
            await resizedFile.OpenReadStream().ReadAsync(buffer);
            profileImageUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
    }
}
