@page "/diary/add"
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager

<EntryForm Entry="newEntry"
           IsEdit="false"
           IsSubmitting="isSaving"
           ErrorMessage="errorMessage"
           OnSave="HandleSave"
           OnCancel="Cancel" />

@code {
    private DiaryEntry newEntry = new DiaryEntry { Date = DateTime.Today };
    private string errorMessage = "";
    private bool isSaving = false;

    private async Task<bool> HandleSave(DiaryEntry entry, IBrowserFile? selectedImage)
    {
        errorMessage = "";
        isSaving = true;
        try
        {
            var success = await DiaryService.SaveEntryAsync(entry, selectedImage);
            if (success)
            {
                NavigationManager.NavigateTo("/diary");
            }
            else
            {
                errorMessage = "Failed to save the diary entry. This may be due to a connection issue or missing required information.";
            }
            return success;
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}. Please ensure the API is running at http://localhost:5105";
            return false;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/diary");
    }
}
