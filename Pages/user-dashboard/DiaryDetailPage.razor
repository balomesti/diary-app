@page "/diary/{Id:int}"
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>@(entry?.Title ?? "Loading...") - Diary Me</PageTitle>

<div class="diary-detail-page">
    <div class="detail-wrapper">

        <div class="top-actions">
            <button class="btn-back" @onclick="GoBack">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to List
            </button>
            <div class="action-buttons">
                <button class="btn-edit" @onclick="EditEntry">Edit Entry</button>
                <button class="btn-delete" @onclick="DeleteEntry">Delete</button>
            </div>
        </div>

        @if (entry == null)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Retrieving your memory...</p>
            </div>
        }
        else
        {
            <article class="journal-page">

                <header class="journal-header">
                    <div class="journal-datetime">
                        @entry.Date.ToString("MMMM d, yyyy") &bull; @entry.Date.ToString("h:mm tt")
                    </div>
                    <h1 class="journal-title">@entry.Title</h1>

                    @if (!string.IsNullOrEmpty(entry.Location) || !string.IsNullOrEmpty(entry.Weather) || !string.IsNullOrEmpty(entry.Mood))
                    {
                        <div class="context-ribbon">
                            @if (!string.IsNullOrEmpty(entry.Location))
                            {
                                <span class="context-pill">📍 @entry.Location</span>
                            }
                            @if (!string.IsNullOrEmpty(entry.Weather))
                            {
                                <span class="context-pill">⛅ @entry.Weather</span>
                            }
                            @if (!string.IsNullOrEmpty(entry.Mood))
                            {
                                <span class="context-pill">@GetMoodEmoji(entry.Mood) @entry.Mood</span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(entry.Tags))
                    {
                        <div class="tags-row">
                            @foreach (var tag in entry.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="tag">@tag.Trim()</span>
                            }
                        </div>
                    }
                </header>

                @if (!string.IsNullOrEmpty(entry.ImageUrls))
                {
                    <div class="journal-gallery">
                        @foreach (var url in entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="gallery-item">
                                <img src="@($"http://localhost:5105{url}")" alt="@entry.Title" @onclick="() => OpenImage(url)" />
                            </div>
                        }
                    </div>
                }

                <div class="journal-body">
                    @foreach (var paragraph in entry.Content.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.None))
                    {
                        <p>@paragraph</p>
                    }
                </div>

            </article>
        }

    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private DiaryEntry? entry;

    protected override async Task OnInitializedAsync()
    {
        entry = await DiaryService.GetEntryByIdAsync(Id);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/diary");
    }

    private void EditEntry()
    {
        NavigationManager.NavigateTo($"/diary/edit/{Id}");
    }

    private async Task DeleteEntry()
    {
        if (entry == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete \"{entry.Title}\"?");
        if (confirmed)
        {
            await DiaryService.DeleteEntryAsync(entry);
            NavigationManager.NavigateTo("/diary");
        }
    }

    private async Task OpenImage(string url)
    {
        await JSRuntime.InvokeVoidAsync("open", $"http://localhost:5105{url}", "_blank");
    }

    private static string GetMoodEmoji(string mood) => mood.ToLower() switch
    {
        "terrible" => "😢",
        "bad" => "😕",
        "okay" => "😐",
        "good" => "😊",
        "amazing" => "✨",
        _ => "😊"
    };
}
