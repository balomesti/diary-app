@page "/diary/{EntryId:int}"
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <p>Loading...</p>
}
else if (entry == null)
{
    <p role="alert">Entry not found.</p>
}
else
{
    <section class="entry-detail-hero">
        <div class="entry-detail-hero-inner">
            <div class="entry-detail-profile">
                <div class="entry-detail-avatar">
                    @if (!string.IsNullOrWhiteSpace(entry.ImageUrl))
                    {
                        <img src="@($"http://localhost:5105{entry.ImageUrl}")" alt="@entry.Title" />
                    }
                </div>

                <div class="entry-detail-meta">
                    <h1 class="entry-detail-title">@entry.Title</h1>
                    <div class="entry-detail-tags">
                        <p class="entry-detail-subtitle">@entry.Content</p>
                    </div>
                        <span class="entry-detail-tag">@entry.Date.ToString("yyyy-MM-dd")</span>
                </div>
            </div>

            <div class="entry-detail-actions">
                <button class="entry-detail-btn entry-detail-btn-outline" type="button" @onclick="DeleteEntryAsync" disabled="@isDeleting">
                    @(isDeleting ? "Deleting..." : "Delete Entry")
                </button>
                <button class="entry-detail-btn entry-detail-btn-solid" type="button" disabled>
                    Edit Entry
                </button>
            </div>
        </div>
    </section>

    <section class="entry-detail-content">
        <div class="entry-detail-content-inner">
            <div class="entry-detail-highlights-header">
                <div>
                    <h2 class="entry-detail-section-title">Key Highlights</h2>
                    <p class="entry-detail-section-subtitle">Important moments that stood out today:</p>
                    <button class="entry-detail-add-highlight" type="button">Add Highlight</button>
                </div>
            </div>

            <div class="entry-detail-highlights-grid">
                @foreach (var highlight in highlights)
                {
                    <article class="entry-detail-highlight-card">
                        <div class="entry-detail-highlight-icon">
                            <span>@highlight.Icon</span>
                        </div>
                        <h3 class="entry-detail-highlight-title">@highlight.Title</h3>
                        <p class="entry-detail-highlight-desc">@highlight.Description</p>
                        <div class="entry-detail-highlight-time">@highlight.Time</div>
                    </article>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public int EntryId { get; set; }

    private DiaryEntry? entry;
    private bool isLoading = true;
    private bool isDeleting = false;

    private readonly List<HighlightCard> highlights = new()
    {
        new HighlightCard("🌅", "Sunrise Hike", "An early start with the rising sun.", "5:30 AM"),
        new HighlightCard("🏕️", "Camping", "Set up camp near the lake.", "1:00 PM")
    };

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        try
        {
            var entries = await DiaryService.GetEntriesAsync();
            entry = entries.FirstOrDefault(e => e.Id == EntryId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteEntryAsync()
    {
        if (entry == null)
        {
            return;
        }

        isDeleting = true;
        try
        {
            await DiaryService.DeleteEntryAsync(entry);
            NavigationManager.NavigateTo("/diary");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private record HighlightCard(string Icon, string Title, string Description, string Time);
}
