@page "/news"
@inject DiaryService DiaryService

<PageTitle>News</PageTitle>

<section class="announcements-hero">
    <div class="announcements-hero-inner">
        <h1>Updates</h1>
        <p>News posts from the admin team.</p>
    </div>
</section>

<section class="announcements-section">
    <div class="announcements-grid">
        @if (!string.IsNullOrEmpty(loadError))
        {
            <p role="alert">@loadError</p>
        }
        else if (isLoading)
        {
            <p>Loading...</p>
        }
        else if (updates.Count == 0)
        {
            <p>No updates found.</p>
        }
        else
        {
            @foreach (var item in updates)
            {
                <article class="announcement-card">
                    <div class="announcement-card-row">
                        <div class="announcement-thumb" style="@ThumbStyle(item)"></div>
                        <div class="announcement-body">
                            <h2 class="announcement-title">@item.Title</h2>
                            <p class="announcement-text">@item.Description</p>  

                            <div class="announcement-tags">
                                <span class="announcement-tag">@item.Kind</span>
                            </div>
                        </div>
                    </div>

                    <div class="announcement-meta">
                        <span class="announcement-avatar"></span>
                        <span class="announcement-author">@item.Author</span>
                    </div>
                </article>
            }
        }
    </div>
</section>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<UpdateItem> updates = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostDto>("api/Admin/news");

            updates = items
                .Select(n => new UpdateItem
                {
                    Kind = "News",
                    Title = n.Title,
                    Description = n.Content,
                    Author = n.Author,
                    CreatedAt = n.CreatedAt,
                    ImageUrl = n.ImageUrl
                })
                .OrderByDescending(x => x.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private string ThumbStyle(UpdateItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.ImageUrl))
        {
            return $"background-image: url('{item.ImageUrl}'); background-size: cover; background-position: center;";
        }

        return "background: #e5e7eb;";
    }

    private sealed class UpdateItem
    {
        public string Kind { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public string ImageUrl { get; set; } = "";
    }

    private sealed class NewsPostDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
