@page "/"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Diary Me - Login</PageTitle>

<div class="signin-container">
    <div class="login-wrapper">
        <!-- Left Side: Welcome Panel -->
        <div class="welcome-section">
            <video autoplay muted loop playsinline class="welcome-video">
                <source src="images/signin.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            <div class="welcome-content">
                <h1>Welcome to Diary Me</h1>
                <p>Please log in to access your diary.</p>
                <button class="btn-outline" @onclick='() => NavigationManager.NavigateTo("/register")'>Sign Up</button>
            </div>
        </div>

        <!-- Right Side: Form Panel -->
        <div class="form-section">
            <h2>Login</h2>
            <p>Enter your credentials below.</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            
            <form @onsubmit="HandleLogin">
                <div class="input-group">
                    <label>Email</label>
                    <input type="email" @bind="loginModel.Email" placeholder="Enter your email" required />
                    <small>We'll never share your email with anyone.</small>
                </div>
                
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" @bind="loginModel.Password" placeholder="Enter your password" required />
                    <small>Make sure it's at least 8 characters long.</small>
                </div>
                
                <div class="button-group">
                    <button type="button" class="btn-outline" @onclick='() => NavigationManager.NavigateTo("/forgot-password")'>Forgot Password</button>
                    <button type="submit" class="btn-solid" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>Logging in...</span>
                        }
                        else
                        {
                            <span>Login</span>
                        }
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new LoginRequest();
    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleLogin()
    {
        errorMessage = "";
        isSubmitting = true;

        try
        {
            var success = await AuthService.Login(loginModel.Email, loginModel.Password);
            if (success)
            {
                if (loginModel.Email.EndsWith("@office.com", StringComparison.OrdinalIgnoreCase))
                {
                    NavigationManager.NavigateTo("/admin/dashboard");
                }
                else
                {
                    NavigationManager.NavigateTo("/home");
                }
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred during login. Please ensure the API is running and accessible.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class LoginRequest
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
