@page "/register"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Diary Me - Register</PageTitle>

<div class="signin-container">
    <div class="login-wrapper">
        <!-- Left Side: Welcome Panel -->
        <div class="welcome-section">
            <video autoplay muted loop playsinline class="welcome-video">
                <source src="images/signin.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            <div class="welcome-content">
                <h1>Create an Account</h1>
                <p>Start your digital diary today.</p>
                <button class="btn-outline" @onclick='() => NavigationManager.NavigateTo("/")'>Login</button>
            </div>
        </div>

        <!-- Right Side: Form Panel -->
        <div class="form-section">
            <h2>Register</h2>
            <p>Enter your details below to create an account.</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            
            <form @onsubmit="HandleRegister">
                <div class="input-group">
                    <label>Full Name</label>
                    <input type="text" @bind="registerModel.Username" placeholder="Enter your full name" required />
                </div>

                <div class="input-group">
                    <label>Email</label>
                    <input type="email" @bind="registerModel.Email" placeholder="Enter your email" required />
                </div>
                
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" @bind="registerModel.Password" placeholder="Create a password" required />
                    <small>Make sure it's at least 8 characters long.</small>
                </div>
                
                <div class="button-group">
                    <button type="submit" class="btn-solid" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>Registering...</span>
                        }
                        else
                        {
                            <span>Register</span>
                        }
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new RegisterRequest();
    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        errorMessage = "";
        isSubmitting = true;

        try
        {
            var success = await AuthService.Register(registerModel.Username, registerModel.Email, registerModel.Password);
            if (success)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = "Registration failed. Email might already be in use.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred during registration. Please ensure the API is running.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterRequest
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
