@page "/register"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<div class="auth-page">
    <div class="auth-header">
        <h1>Create an Account</h1>
        <p>Start your digital diary today.</p>
        <div class="auth-header-actions">
            <button class="btn-solid-black" @onclick='() => NavigationManager.NavigateTo("/register")'>Sign Up</button>
            <button class="btn-outline-white" @onclick='() => NavigationManager.NavigateTo("/")'>Login</button>
        </div>
    </div>

    <div class="auth-container">
        <div class="auth-info">
            <h2>Register</h2>
            <p>Enter your details below to create an account.</p>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
        </div>

        <div class="auth-form-container">
            <form class="auth-form" @onsubmit="HandleRegister">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" @bind="registerModel.Username" placeholder="Enter your full name" required />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" @bind="registerModel.Email" placeholder="Enter your email" required />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input type="password" @bind="registerModel.Password" placeholder="Create a password" required />
                </div>

                <div class="auth-form-actions">
                    <button type="submit" class="btn-solid-black" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>Registering...</span>
                        }
                        else
                        {
                            <span>Register</span>
                        }
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new RegisterRequest();
    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        errorMessage = "";
        isSubmitting = true;

        try
        {
            var success = await AuthService.Register(registerModel.Username, registerModel.Email, registerModel.Password);
            if (success)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = "Registration failed. Email might already be in use.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred during registration. Please ensure the API is running.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterRequest
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
