@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inject DiaryService DiaryService

<PageTitle>Admin Dashboard</PageTitle>

<link href="css/pages/AdminPage.css" rel="stylesheet" />

<div class="admin-dashboard-container">
    <main class="admin-hero-wrapper">
        <!-- LEFT SIDE: ADMIN TEXT & ACTIONS -->
        <div class="admin-content-hero">
            <h1>Welcome to the<br />Admin Dashboard</h1>
            <p>Manage your diary entries, explore posts, and notices all in one place.</p>

            <div class="admin-hero-buttons">
                <button class="btn-outline" type="button" @onclick="GoToManage">Manage</button>
                <button class="btn-solid" type="button" @onclick="GoToCreate">Create New Post</button>
            </div>
        </div>

        <!-- RIGHT SIDE: ADMIN IMAGE -->
        <div class="admin-image-wrapper">
            <img src="https://images.unsplash.com/photo-1517842645767-c639042777db?q=80&w=800&auto=format&fit=crop" alt="Person writing in a diary">
        </div>
    </main>

<section class="admin-dashboard-explore" style="background: transparent; padding: 20px 0;">
    <div style="max-width: 1100px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 40px;">
            <h2 style="font-size: 2.5rem; font-weight: 800; color: #0f172a; margin-bottom: 12px;">Latest Explore Posts</h2>
            <p style="font-size: 1.1rem; color: #64748b; max-width: 600px; margin: 0 auto;">Review recently published content visible to all users.</p>
        </div>

        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="admin-create-status error" style="padding: 15px; border-radius: 8px; background: #fee2e2; color: #991b1b; text-align: center;">
                @loadError
            </div>
        }
        else if (isLoading)
        {
            <p style="text-align: center;">Loading...</p>
        }
        else if (latestNews.Count == 0)
        {
            <p style="text-align: center;">No explore posts found.</p>
        }
        else
        {
            <div class="admin-carousel-container" style="position: relative; width: 100%;">
                <div class="admin-carousel-track" style="overflow: hidden; border-radius: 16px; background: #fff; border: 1px solid var(--border-color); box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.08);">
                    @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                    {
                        <div class="admin-carousel-item" style="display: @(index == currentSlide ? "block" : "none");">
                            <div class="admin-carousel-media" style="width: 100%; height: 380px; background: #fdfbf7; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(news.VideoUrl))
                                {
                                    <video style="width: 100%; height: 100%; object-fit: cover;" autoplay loop muted playsinline>
                                        <source src="@news.VideoUrl" type="video/mp4">
                                    </video>
                                }
                                else if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="Post media" style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; background: #ececec; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    </div>
                                }
                            </div>
                            <div class="admin-carousel-content" style="padding: 24px; border-top: 1px solid var(--border-color); text-align: center;">
                                <h3 style="margin: 0 0 12px; font-size: 1.6rem; font-weight: 800; color: var(--text-main); font-family: 'Playfair Display', serif;">@news.Title</h3>
                                <p style="margin: 0 auto; color: var(--text-light); font-size: 1.05rem; line-height: 1.6; max-width: 800px;">@news.Content</p>
                            </div>
                        </div>
                    }
                </div>

                @if (latestNews.Count > 1)
                {
                    <button type="button" @onclick="PrevSlide" style="position: absolute; top: 190px; left: -25px; width: 50px; height: 50px; border-radius: 50%; background: #fff; border: 1px solid var(--border-color); box-shadow: 0 8px 16px rgba(44, 35, 31, 0.12); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-50%) scale(1.1)'; this.style.boxShadow='0 10px 20px rgba(44, 35, 31, 0.15)'" onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.boxShadow='0 8px 16px rgba(44, 35, 31, 0.12)'">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-main)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button type="button" @onclick="NextSlide" style="position: absolute; top: 190px; right: -25px; width: 50px; height: 50px; border-radius: 50%; background: #fff; border: 1px solid var(--border-color); box-shadow: 0 8px 16px rgba(44, 35, 31, 0.12); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-50%) scale(1.1)'; this.style.boxShadow='0 10px 20px rgba(44, 35, 31, 0.15)'" onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.boxShadow='0 8px 16px rgba(44, 35, 31, 0.12)'">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-main)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>

                    <div class="admin-carousel-dots" style="display: flex; justify-content: center; gap: 10px; margin-top: 24px;">
                        @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                        {
                            <div @onclick="() => currentSlide = index" style="width: @(index == currentSlide ? "32px" : "10px"); height: 10px; border-radius: 5px; background: @(index == currentSlide ? "#0f172a" : "#cbd5e1"); cursor: pointer; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</section>
</div>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<NewsPostItem> latestNews = new();
    private int currentSlide = 0;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostItem>("api/Admin/news");
            latestNews = items.Take(5).ToList(); // Taking up to 5 for the carousel
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide + 1) % latestNews.Count;
    }

    private void PrevSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide - 1 + latestNews.Count) % latestNews.Count;
    }

    private void GoToManage()
    {
        NavigationManager.NavigateTo("/admin/manage");
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/admin/create");
    }

    private sealed class NewsPostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
