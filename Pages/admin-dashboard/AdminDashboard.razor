@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inject DiaryService DiaryService

<PageTitle>Admin Dashboard</PageTitle>

<div class="admin-dashboard-container">
    <main class="admin-hero-wrapper">
        <!-- LEFT SIDE: ADMIN TEXT & ACTIONS -->
        <div class="admin-content-hero">
            <h1>Welcome to the<br />Admin Dashboard</h1>
            <p>Manage your diary entries, explore posts, and notices all in one place.</p>

            <div class="admin-hero-buttons">
                <button class="btn-outline" type="button" @onclick="GoToManage">Manage</button>
                <button class="btn-solid" type="button" @onclick="GoToCreate">Create New Post</button>
            </div>
        </div>

        <!-- RIGHT SIDE: ADMIN IMAGE -->
        <div class="admin-image-wrapper">
            <img src="https://images.unsplash.com/photo-1517842645767-c639042777db?q=80&w=800&auto=format&fit=crop" alt="Person writing in a diary">
        </div>
    </main>

<section class="admin-dashboard-explore">
    <div>
        <div class="admin-explore-header">
            <h2>Latest Explore Posts</h2>
            <p>Review recently published content visible to all users.</p>
        </div>

        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="admin-create-status error">
                @loadError
            </div>
        }
        else if (isLoading)
        {
            <p class="admin-explore-loading">Loading...</p>
        }
        else if (latestNews.Count == 0)
        {
            <p class="admin-explore-empty">No explore posts found.</p>
        }
        else
        {
            <div class="admin-carousel-container">
                <div class="admin-carousel-track">
                    @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                    {
                        <div class="admin-carousel-item @(index == currentSlide ? "active" : "")">
                            <div class="admin-carousel-media">
                                @if (!string.IsNullOrEmpty(news.VideoUrl))
                                {
                                    <video autoplay loop muted playsinline>
                                        <source src="@news.VideoUrl" type="video/mp4">
                                    </video>
                                }
                                else if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="Post media" />
                                }
                                else
                                {
                                    <div class="admin-carousel-media-placeholder">
                                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    </div>
                                }
                            </div>
                            <div class="admin-carousel-content">
                                <h3>@news.Title</h3>
                                <p>@news.Content</p>
                            </div>
                        </div>
                    }
                </div>

                @if (latestNews.Count > 1)
                {
                    <button type="button" class="admin-carousel-btn admin-carousel-btn-prev" @onclick="PrevSlide">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-main)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button type="button" class="admin-carousel-btn admin-carousel-btn-next" @onclick="NextSlide">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-main)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>

                    <div class="admin-carousel-dots">
                        @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                        {
                            <div class="admin-carousel-dot @(index == currentSlide ? "active" : "")" @onclick="() => currentSlide = index"></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</section>
</div>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<NewsPostItem> latestNews = new();
    private int currentSlide = 0;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostItem>("api/Admin/news");
            latestNews = items.Take(5).ToList(); // Taking up to 5 for the carousel
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide + 1) % latestNews.Count;
    }

    private void PrevSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide - 1 + latestNews.Count) % latestNews.Count;
    }

    private void GoToManage()
    {
        NavigationManager.NavigateTo("/admin/manage");
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/admin/create");
    }

    private sealed class NewsPostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
