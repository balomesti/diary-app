@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager

<PageTitle>Admin Dashboard</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Welcome to the Admin<br />Dashboard</h1>
        <p>Manage your diary entries, news posts, and announcements all in one place.</p>

        <div class="admin-dashboard-hero-actions">
            <button class="admin-btn-outline admin-btn-wide" type="button" @onclick="GoToPosts">View All Post</button>
            <button class="admin-btn-solid admin-btn-wide" type="button" @onclick="GoToCreate">Create New Post</button>
        </div>
    </div>
</section>

<section class="admin-dashboard-main" id="news">
    <div class="admin-dashboard-main-inner">
        <div class="admin-dashboard-preview">
            <video autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px; display: block;">
                <source src="images/Diary-gif.mp4" type="video/mp4" />
                Your browser does not support the video tag.
            </video>
        </div>

        <div class="admin-dashboard-content">
            <h2 class="admin-dashboard-title">News Post</h2>
            <p class="admin-dashboard-subtitle">Published news posts will be visible to all users.</p>

            <article class="admin-dashboard-formcard">
                <div class="admin-dashboard-formthumb"></div>
                <div class="admin-dashboard-formbody">
                    <h3 class="admin-dashboard-formtitle">"Latest Posts"</h3>
                    <p class="admin-dashboard-formtext">Fill in the details below to generate a news post.</p>

                    <div class="admin-dashboard-chips">
                        <span class="admin-dashboard-chip">Title</span>
                        <span class="admin-dashboard-chip">Content</span>
                        <span class="admin-dashboard-chip">Image</span>
                    </div>

                    <div class="admin-dashboard-meta">
                        <span class="admin-dashboard-avatar"></span>
                        <span class="admin-dashboard-author">Admin</span>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

@code {
    private void GoToPosts()
    {
        NavigationManager.NavigateTo("/admin/posts");
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/admin/create");
    }
}
