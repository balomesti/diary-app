@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inject DiaryService DiaryService

<PageTitle>Admin Dashboard</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Welcome to the Admin<br />Dashboard</h1>
        <p>Manage your diary entries, news posts, and announcements all in one place.</p>

        <div class="admin-dashboard-hero-actions">
            <button class="admin-btn-outline admin-btn-wide" type="button" @onclick="GoToPosts">View All Post</button>
            <button class="admin-btn-solid admin-btn-wide" type="button" @onclick="GoToCreate">Create New Post</button>
        </div>
    </div>
</section>

<section class="admin-dashboard-main" id="news">
    <div class="admin-dashboard-main-inner">
        <div class="admin-dashboard-preview">
            <video autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px; display: block;">
                <source src="images/Diary-gif.mp4" type="video/mp4" />
                Your browser does not support the video tag.
            </video>
        </div>

        <div class="admin-dashboard-content">
            <h2 class="admin-dashboard-title">News Post</h2>
            <p class="admin-dashboard-subtitle">Published news posts will be visible to all users.</p>

            @if (!string.IsNullOrEmpty(loadError))
            {
                <div class="admin-create-status error" style="margin-top: 20px; padding: 15px; border-radius: 8px; background: #fee2e2; color: #991b1b;">
                    @loadError
                </div>
            }
            else if (isLoading)
            {
                <p>Loading...</p>
            }
            else if (latestNews.Count == 0)
            {
                <p>No news posts found.</p>
            }
            else
            {
                @foreach (var news in latestNews)
                {
                    <article class="admin-dashboard-formcard">
                        @if (!string.IsNullOrEmpty(news.ImageUrl))
                        {
                            <img src="@news.ImageUrl" alt="Post thumbnail" class="admin-dashboard-formthumb" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="admin-dashboard-formthumb"></div>
                        }
                        <div class="admin-dashboard-formbody">
                            <h3 class="admin-dashboard-formtitle">@news.Title</h3>
                            <p class="admin-dashboard-formtext">@news.Content</p>
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<NewsPostItem> latestNews = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostItem>("api/Admin/news");
            latestNews = items.Take(3).ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToPosts()
    {
        NavigationManager.NavigateTo("/admin/posts");
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/admin/create");
    }

    private sealed class NewsPostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
