@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inject DiaryService DiaryService

<PageTitle>Admin Dashboard</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Welcome to the Admin<br />Dashboard</h1>
        <p>Manage your diary entries, explore posts, and notices all in one place.</p>

        <div class="admin-dashboard-hero-actions">
            <button class="admin-btn-outline admin-btn-wide" type="button" @onclick="GoToManage">Manage Content</button>
            <button class="admin-btn-solid admin-btn-wide" type="button" @onclick="GoToCreate">Create New Post</button>
        </div>
    </div>
</section>

<section class="admin-dashboard-main" id="preview" style="padding: 60px 20px;">
    <div class="admin-dashboard-main-inner" style="max-width: 1100px; margin: 0 auto;">
        <div class="admin-dashboard-preview" style="margin-bottom: 0;">
            <video autoplay loop muted playsinline style="width: 100%; height: 500px; object-fit: cover; border-radius: 16px; display: block; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);">
                <source src="images/Diary-gif.mp4" type="video/mp4" />
                Your browser does not support the video tag.
            </video>
        </div>
    </div>
</section>


<section class="admin-dashboard-explore" style="background: #f8fafc; padding: 60px 20px;">
    <div style="max-width: 1100px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 40px;">
            <h2 style="font-size: 2.5rem; font-weight: 800; color: #0f172a; margin-bottom: 12px;">Latest Explore Posts</h2>
            <p style="font-size: 1.1rem; color: #64748b; max-width: 600px; margin: 0 auto;">Review recently published content visible to all users.</p>
        </div>

        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="admin-create-status error" style="padding: 15px; border-radius: 8px; background: #fee2e2; color: #991b1b; text-align: center;">
                @loadError
            </div>
        }
        else if (isLoading)
        {
            <p style="text-align: center;">Loading...</p>
        }
        else if (latestNews.Count == 0)
        {
            <p style="text-align: center;">No explore posts found.</p>
        }
        else
        {
            <div class="admin-carousel-container" style="position: relative; width: 100%;">
                <div class="admin-carousel-track" style="overflow: hidden; border-radius: 16px; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);">
                    @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                    {
                        <div class="admin-carousel-item" style="display: @(index == currentSlide ? "block" : "none");">
                            <div class="admin-carousel-media" style="width: 100%; height: 500px; background: #000; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(news.VideoUrl))
                                {
                                    <video style="width: 100%; height: 100%; object-fit: cover;" autoplay loop muted playsinline>
                                        <source src="@news.VideoUrl" type="video/mp4">
                                    </video>
                                }
                                else if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="Post media" style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; background: #ececec; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    </div>
                                }
                            </div>
                            <div class="admin-carousel-content" style="padding: 32px; border-top: 1px solid #f1f5f9; text-align: center;">
                                <h3 style="margin: 0 0 16px; font-size: 1.8rem; font-weight: 800; color: #0f172a;">@news.Title</h3>
                                <p style="margin: 0 auto; color: #475569; font-size: 1.1rem; line-height: 1.7; max-width: 800px;">@news.Content</p>
                            </div>
                        </div>
                    }
                </div>

                @if (latestNews.Count > 1)
                {
                    <button type="button" @onclick="PrevSlide" style="position: absolute; top: 250px; left: -22px; width: 50px; height: 50px; border-radius: 50%; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 8px 16px rgba(0,0,0,0.12); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: all 0.2s;" onmouseover="this.style.transform='scale(1.1)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.15)'" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.12)'">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button type="button" @onclick="NextSlide" style="position: absolute; top: 250px; right: -22px; width: 50px; height: 50px; border-radius: 50%; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 8px 16px rgba(0,0,0,0.12); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: all 0.2s;" onmouseover="this.style.transform='scale(1.1)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.15)'" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.12)'">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>

                    <div class="admin-carousel-dots" style="display: flex; justify-content: center; gap: 10px; margin-top: 24px;">
                        @foreach (var (news, index) in latestNews.Select((v, i) => (v, i)))
                        {
                            <div @onclick="() => currentSlide = index" style="width: @(index == currentSlide ? "32px" : "10px"); height: 10px; border-radius: 5px; background: @(index == currentSlide ? "#0f172a" : "#cbd5e1"); cursor: pointer; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<NewsPostItem> latestNews = new();
    private int currentSlide = 0;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostItem>("api/Admin/news");
            latestNews = items.Take(5).ToList(); // Taking up to 5 for the carousel
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide + 1) % latestNews.Count;
    }

    private void PrevSlide()
    {
        if (latestNews.Count == 0) return;
        currentSlide = (currentSlide - 1 + latestNews.Count) % latestNews.Count;
    }

    private void GoToManage()
    {
        NavigationManager.NavigateTo("/admin/manage");
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/admin/create");
    }

    private sealed class NewsPostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
