@page "/admin"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<div class="admin-auth-page">
    <div class="admin-auth-hero">
        <h1>Admin Sign In</h1>
        <p>Use your @@office.com email to access the admin dashboard.</p>
    </div>

    <div class="admin-auth-container">
        <div class="admin-auth-card">
            <h2>Login</h2>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <form class="admin-auth-form" @onsubmit="HandleLogin">
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" @bind="loginModel.Email" placeholder="name@office.com" required />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input type="password" @bind="loginModel.Password" placeholder="Enter your password" required />
                </div>

                <div class="admin-auth-actions">
                    <button type="button" class="admin-btn-outline" @onclick="GoBack">Back</button>
                    <button type="submit" class="admin-btn-solid" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleLogin()
    {
        errorMessage = "";

        if (!loginModel.Email.EndsWith("@office.com", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "This is an admin login. Please use an @office.com email.";
            return;
        }

        isSubmitting = true;

        try
        {
            var success = await AuthService.Login(loginModel.Email, loginModel.Password);
            if (success)
            {
                NavigationManager.NavigateTo("/admin/dashboard");
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred during login. Please ensure the API is running and accessible.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    public sealed class LoginRequest
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
