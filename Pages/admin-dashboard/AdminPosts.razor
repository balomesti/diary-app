@page "/admin/posts"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Posts</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Posts</h1>
        <p>Create and manage posts for users.</p>
    </div>
</section>

<section class="admin-dashboard-main">
    <div class="admin-dashboard-main-inner">
        <div class="admin-dashboard-preview"></div>
        <div class="admin-dashboard-content">
            <h2 class="admin-dashboard-title">Coming Soon</h2>
            <p class="admin-dashboard-subtitle">This page will manage posts and announcements.</p>
        </div>
    </div>
</section>
