@page "/admin/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager

<PageTitle>Admin Content Create</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Create Content</h1>
        <p>Generate explore posts and notices for users.</p>

        <div class="admin-create-toggle" role="tablist" aria-label="Create mode">
            <button type="button" class="@ModeButtonClass(CreateMode.Explore)" @onclick="() => SelectMode(CreateMode.Explore)">Create Explore</button>
            <button type="button" class="@ModeButtonClass(CreateMode.Notice)" @onclick="() => SelectMode(CreateMode.Notice)">Create Notice</button>
        </div>
    </div>
</section>

<section class="admin-create">
    <div class="admin-create-inner">
        <div class="admin-create-left">
            @if (mode == CreateMode.Explore)
            {
                <h2 class="admin-create-title">Create Explore Post</h2>
            }
            else
            {
                <h2 class="admin-create-title">Create Notice</h2>
            }
            
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="admin-create-status @(isError ? "error" : "success")" style="margin-top: 20px; padding: 15px; border-radius: 8px; @(isError ? "background: #fee2e2; color: #991b1b;" : "background: #dcfce7; color: #166534;")">
                    @statusMessage
                </div>
            }
        </div>

        <div class="admin-create-right">
            @if (mode == CreateMode.Explore)
            {
                <EditForm Model="@exploreModel" OnValidSubmit="PublishExploreAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="admin-create-form">
                        <div class="admin-create-field">
                            <label class="admin-create-label">Post Title</label>
                            <InputText class="admin-create-input" @bind-Value="exploreModel.Title" placeholder="Enter the title of the explore post" />
                        </div>

                        <div class="admin-create-field">
                            <label class="admin-create-label">Post Content</label>
                            <InputTextArea class="admin-create-input admin-create-textarea" @bind-Value="exploreModel.Content" placeholder="Write the content of the explore post" />
                        </div>

                        <div class="admin-create-field">
                            <label class="admin-create-label">Image</label>
                            <InputFile class="admin-create-input" OnChange="HandleExploreImageSelected" accept="image/*" />
                        </div>

                        <button type="submit" class="admin-create-submit" disabled="@isSubmitting">
                            @(isSubmitting ? "Publishing..." : "Publish Post")
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                <EditForm Model="@noticeModel" OnValidSubmit="PublishNoticeAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="admin-create-form">
                        <div class="admin-create-field">
                            <label class="admin-create-label">Title</label>
                            <InputText class="admin-create-input" @bind-Value="noticeModel.Title" placeholder="Enter the notice title" />
                        </div>

                        <div class="admin-create-field">
                            <label class="admin-create-label">Message</label>
                            <InputTextArea class="admin-create-input admin-create-textarea" @bind-Value="noticeModel.Message" placeholder="Write the notice message" />
                        </div>

                        <button type="submit" class="admin-create-submit" disabled="@isSubmitting">
                            @(isSubmitting ? "Publishing..." : "Publish Notice")
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</section>


@code {
    private CreateMode mode = CreateMode.Explore;
    private bool isSubmitting;
    private string statusMessage = "";
    private bool isError = false;
    private ExplorePostModel exploreModel = new();
    private NoticeModel noticeModel = new();

    private void SelectMode(CreateMode nextMode)
    {
        mode = nextMode;
        statusMessage = "";
    }

    private string ModeButtonClass(CreateMode buttonMode)
    {
        return mode == buttonMode
            ? "admin-create-toggle-btn admin-create-toggle-btn-active"
            : "admin-create-toggle-btn";
    }

    private enum CreateMode
    {
        Explore,
        Notice
    }

    private async Task PublishExploreAsync()
    {
        isSubmitting = true;
        statusMessage = "";
        try
        {
            await DiaryService.CreateNewsAsync(exploreModel.Title, exploreModel.Content, exploreImageFile);

            statusMessage = "Explore post published successfully!";
            isError = false;
            exploreModel = new();
            exploreImageFile = null;
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task PublishNoticeAsync()
    {
        isSubmitting = true;
        statusMessage = "";
        try
        {
            await DiaryService.CreateAnnouncementAsync(new
            {
                title = noticeModel.Title,
                message = noticeModel.Message
            });

            statusMessage = "Notice published successfully!";
            isError = false;
            noticeModel = new();
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ExplorePostModel
    {
        [Required]
        public string Title { get; set; } = "";
        [Required]
        public string Content { get; set; } = "";
    }

    private sealed class NoticeModel
    {
        [Required]
        public string Title { get; set; } = "";
        [Required]
        public string Message { get; set; } = "";
    }

    private IBrowserFile? exploreImageFile;

    private void HandleExploreImageSelected(InputFileChangeEventArgs args)
    {
        exploreImageFile = args.File;
    }
}
