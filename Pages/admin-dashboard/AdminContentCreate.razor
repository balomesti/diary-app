@page "/admin/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Admin Content Create</PageTitle>

<div class="admin-create-container">
    <div class="entry-container">
        <div class="entry-header">
            <h1>@(mode == CreateMode.Explore ? "Create Explore Post" : "Create Notice")</h1>
            <p>Generate explore posts and notices for users.</p>
        </div>

        <div class="admin-create-toggle" role="tablist" aria-label="Create mode">
            <button type="button" class="@ModeButtonClass(CreateMode.Explore)" @onclick="() => SelectMode(CreateMode.Explore)">Create Explore</button>
            <button type="button" class="@ModeButtonClass(CreateMode.Notice)" @onclick="() => SelectMode(CreateMode.Notice)">Create Notice</button>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="admin-create-status @(isError ? "error" : "success")">
                @statusMessage
            </div>
        }

        @if (mode == CreateMode.Explore)
        {
            <EditForm Model="@exploreModel" OnValidSubmit="PublishExploreAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>Post Title</label>
                    <InputText class="form-control" @bind-Value="exploreModel.Title" placeholder="Enter the title of the explore post" />
                </div>

                <div class="form-group">
                    <label>Post Content</label>
                    <InputTextArea class="form-control" @bind-Value="exploreModel.Content" placeholder="Write the content of the explore post" />
                </div>

                <div class="form-group">
                    <label class="field-label">Images</label>
                    <label class="upload-zone" for="explore-file-input">
                        <InputFile id="explore-file-input" OnChange="HandleExploreImageSelected" accept="image/*" multiple style="display:none" />
                        <div class="upload-icon">📷</div>
                        <div>Tap to add photos</div>
                    </label>
                    @if (exploreImageFiles.Any())
                    {
                        <div class="image-previews-grid">
                            @foreach (var img in exploreImageFiles)
                            {
                                <div class="image-preview-container">
                                    <img src="@img.PreviewUrl" alt="Image Preview" class="image-preview" />
                                    <button type="button" class="image-preview-remove" @onclick="() => RemoveImage(img)">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                        <button type="button" class="btn-outline btn-clear" @onclick="ClearImages">Clear All</button>
                    }
                </div>

                <div class="form-group">
                    <label>Video (Optional)</label>
                    <InputFile class="form-control" OnChange="HandleExploreVideoSelected" accept="video/*" />
                    <div class="help-text">MP4 recommended; short loops look best.</div>
                </div>

                <div class="submit-section">
                    <button type="submit" class="btn-solid" disabled="@isSubmitting">
                        @(isSubmitting ? "Publishing..." : "Publish Post")
                    </button>
                </div>
            </EditForm>
        }
        else
        {
            <EditForm Model="@noticeModel" OnValidSubmit="PublishNoticeAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>Title</label>
                    <InputText class="form-control" @bind-Value="noticeModel.Title" placeholder="Enter the notice title" />
                </div>

                <div class="form-group">
                    <label>Message</label>
                    <InputTextArea class="form-control" @bind-Value="noticeModel.Message" placeholder="Write the notice message" />
                </div>

                <div class="submit-section">
                    <button type="submit" class="btn-solid" disabled="@isSubmitting">
                        @(isSubmitting ? "Publishing..." : "Publish Notice")
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>


@code {
    private CreateMode mode = CreateMode.Explore;
    private bool isSubmitting;
    private string statusMessage = "";
    private bool isError = false;
    private ExplorePostModel exploreModel = new();
    private NoticeModel noticeModel = new();

    private void SelectMode(CreateMode nextMode)
    {
        mode = nextMode;
        statusMessage = "";
    }

    private string ModeButtonClass(CreateMode buttonMode)
    {
        return mode == buttonMode
            ? "admin-create-toggle-btn admin-create-toggle-btn-active"
            : "admin-create-toggle-btn";
    }

    private enum CreateMode
    {
        Explore,
        Notice
    }

    private async Task PublishExploreAsync()
    {
        isSubmitting = true;
        statusMessage = "";
        try
        {
            var imageFiles = exploreImageFiles.Select(x => x.File).ToList();
            await DiaryService.CreateNewsAsync(exploreModel.Title, exploreModel.Content, imageFiles, exploreVideoFile);

            statusMessage = "Explore post published successfully!";
            isError = false;
            exploreModel = new();
            exploreImageFiles.Clear();
            exploreVideoFile = null;
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task PublishNoticeAsync()
    {
        isSubmitting = true;
        statusMessage = "";
        try
        {
            await DiaryService.CreateAnnouncementAsync(noticeModel.Title, noticeModel.Message);

            statusMessage = "Notice published successfully!";
            isError = false;
            noticeModel = new();
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ExplorePostModel
    {
        [Required]
        public string Title { get; set; } = "";
        [Required]
        public string Content { get; set; } = "";
    }

    private sealed class NoticeModel
    {
        [Required]
        public string Title { get; set; } = "";
        [Required]
        public string Message { get; set; } = "";
    }

    private IBrowserFile? exploreVideoFile;
    private List<ImageFileEntry> exploreImageFiles = new();

    private async void HandleExploreImageSelected(InputFileChangeEventArgs args)
    {
        foreach (var file in args.GetMultipleFiles())
        {
            var previewUrl = await GetDataUrlAsync(file);
            exploreImageFiles.Add(new ImageFileEntry { File = file, PreviewUrl = previewUrl });
        }
        StateHasChanged();
    }

    private async Task<string> GetDataUrlAsync(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();
        return $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
    }

    private void RemoveImage(ImageFileEntry entry)
    {
        exploreImageFiles.Remove(entry);
        StateHasChanged();
    }

    private void ClearImages()
    {
        exploreImageFiles.Clear();
        StateHasChanged();
    }

    private sealed class ImageFileEntry
    {
        public IBrowserFile File { get; set; } = null!;
        public string? PreviewUrl { get; set; }
    }

    private void HandleExploreVideoSelected(InputFileChangeEventArgs args)
    {
        exploreVideoFile = args.File;
    }
}
