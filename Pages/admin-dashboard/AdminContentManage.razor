@page "/admin/manage"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject DiaryService DiaryService

<PageTitle>Admin Content Manager</PageTitle>

<main class="manager-wrapper">
    
    <!-- LEFT PANEL: Header, Tabs, List Title -->
    <div class="left-panel">
        <h1>Content Manager</h1>
        <p>Manage explore posts and notices for users.</p>

        <div class="tabs-container" role="tablist" aria-label="View mode">
            <button type="button" 
                    class="tab-btn @(mode == ViewMode.Explore ? "active" : "")" 
                    @onclick="() => SelectMode(ViewMode.Explore)">
                Explore
            </button>
            <button type="button" 
                    class="tab-btn @(mode == ViewMode.Notice ? "active" : "")" 
                    @onclick="() => SelectMode(ViewMode.Notice)">
                Notice
            </button>
        </div>

        @if (mode == ViewMode.Explore)
        {
            <h2 class="list-title">Explore Post List</h2>
        }
        else
        {
            <h2 class="list-title">Notice List</h2>
        }

        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="error-msg">
                @loadError
            </div>
        }
    </div>

    <!-- RIGHT PANEL: Cards List -->
    <div class="right-panel">
        @if (mode == ViewMode.Explore)
        {
            @if (isLoading)
            {
                <p class="loading-text">Loading...</p>
            }
            else if (explorePosts.Count == 0)
            {
                <p class="empty-text">No explore posts found.</p>
            }
            else
            {
                @foreach (var news in explorePosts)
                {
                    <div class="post-card">
                        @if (!string.IsNullOrEmpty(news.VideoUrl))
                        {
                            <video class="post-image" controls>
                                <source src="@news.VideoUrl" type="video/mp4">
                            </video>
                        }
                        else if (!string.IsNullOrEmpty(news.ImageUrl))
                        {
                            <img src="@news.ImageUrl" alt="Post thumbnail" class="post-image" />
                        }
                        else
                        {
                            <div class="post-image placeholder"></div>
                        }
                        
                        <div class="post-content">
                            <div class="post-text">
                                <h3>@news.Title</h3>
                                <p>@news.Content</p>
                            </div>
                            <div class="post-actions">
                                <button type="button" class="btn-delete" 
                                        disabled="@(isDeleting && deletingExploreId == news.Id)" 
                                        @onclick="() => DeleteExploreAsync(news.Id)">
                                    @(isDeleting && deletingExploreId == news.Id ? "Deleting..." : "Delete")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            @if (isLoading)
            {
                <p class="loading-text">Loading...</p>
            }
            else if (notices.Count == 0)
            {
                <p class="empty-text">No notices found.</p>
            }
            else
            {
                @foreach (var item in notices)
                {
                    <div class="post-card">
                        <!-- Notices usually don't have images, so we just show the content -->
                        <div class="post-content">
                            <div class="post-text">
                                <h3>@item.Title</h3>
                                <p>@item.Message</p>
                            </div>
                            <div class="post-actions">
                                <button type="button" class="btn-delete" 
                                        disabled="@(isDeleting && deletingNoticeId == item.Id)" 
                                        @onclick="() => DeleteNoticeAsync(item.Id)">
                                    @(isDeleting && deletingNoticeId == item.Id ? "Deleting..." : "Delete")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

</main>

@code {
    private ViewMode mode = ViewMode.Explore;
    private bool isLoading;
    private string loadError = "";
    private bool isDeleting;
    private int? deletingExploreId;
    private int? deletingNoticeId;
    private List<ExplorePostItem> explorePosts = new();
    private List<NoticeItem> notices = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var exploreTask = DiaryService.GetAdminListAsync<ExplorePostItem>("api/Admin/news");
            var noticesTask = DiaryService.GetAdminListAsync<NoticeItem>("api/Admin/announcements");
            await Task.WhenAll(exploreTask, noticesTask);
            explorePosts = exploreTask.Result;
            notices = noticesTask.Result;
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteExploreAsync(int id)
    {
        isDeleting = true;
        deletingExploreId = id;
        loadError = "";
        try
        {
            await DiaryService.DeleteNewsAsync(id);
            explorePosts = explorePosts.Where(x => x.Id != id).ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            deletingExploreId = null;
            isDeleting = false;
        }
    }

    private async Task DeleteNoticeAsync(int id)
    {
        isDeleting = true;
        deletingNoticeId = id;
        loadError = "";
        try
        {
            await DiaryService.DeleteAnnouncementAsync(id);
            notices = notices.Where(x => x.Id != id).ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            deletingNoticeId = null;
            isDeleting = false;
        }
    }

    private void SelectMode(ViewMode nextMode)
    {
        mode = nextMode;
    }

    private enum ViewMode
    {
        Explore,
        Notice
    }

    private sealed class ExplorePostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string VideoUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private sealed class NoticeItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}