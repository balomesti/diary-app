@page "/admin/manage"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject DiaryService DiaryService

<PageTitle>Admin Content Manager</PageTitle>

<section class="admin-dashboard-hero">
    <div class="admin-dashboard-hero-inner">
        <h1>Content Manager</h1>
        <p>Manage explore posts and notices for users.</p>

        <div class="admin-create-toggle" role="tablist" aria-label="View mode">
            <button type="button" class="@ModeButtonClass(ViewMode.Explore)" @onclick="() => SelectMode(ViewMode.Explore)">Explore</button>
            <button type="button" class="@ModeButtonClass(ViewMode.Notice)" @onclick="() => SelectMode(ViewMode.Notice)">Notice</button>
        </div>
    </div>
</section>

<section class="admin-create">
    <div class="admin-create-inner">
        <div class="admin-create-left">
            @if (mode == ViewMode.Explore)
            {
                <h2 class="admin-create-title">Explore Post List</h2>
            }
            else
            {
                <h2 class="admin-create-title">Notice List</h2>
            }

            @if (!string.IsNullOrEmpty(loadError))
            {
                <div class="admin-create-status error" style="margin-top: 20px; padding: 15px; border-radius: 8px; background: #fee2e2; color: #991b1b;">
                    @loadError
                </div>
            }
        </div>

        <div class="admin-create-right">
            @if (mode == ViewMode.Explore)
            {
                <div class="admin-posts-list">
                    @if (isLoading)
                    {
                        <p>Loading...</p>
                    }
                    else if (explorePosts.Count == 0)
                    {
                        <p>No explore posts found.</p>
                    }
                    else
                    {
                        @foreach (var news in explorePosts)
                        {
                            <div class="admin-dashboard-formcard" style="margin-top: 18px;">
                                @if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="Post thumbnail" class="admin-dashboard-formthumb" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="admin-dashboard-formthumb"></div>
                                }
                                <div class="admin-dashboard-formbody">
                                    <h3 class="admin-dashboard-formtitle">@news.Title</h3>
                                    <p class="admin-dashboard-formtext">@news.Content</p>
                                    <div style="margin-top: 12px; display: flex; justify-content: flex-end;">
                                        <button type="button" class="admin-btn-outline" style="border-color: #ef4444; color: #ef4444;" disabled="@(isDeleting && deletingExploreId == news.Id)" @onclick="() => DeleteExploreAsync(news.Id)">
                                            @(isDeleting && deletingExploreId == news.Id ? "Deleting..." : "Delete")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="admin-posts-list">
                    @if (isLoading)
                    {
                        <p>Loading...</p>
                    }
                    else if (notices.Count == 0)
                    {
                        <p>No notices found.</p>
                    }
                    else
                    {
                        @foreach (var item in notices)
                        {
                            <div class="admin-dashboard-formcard" style="margin-top: 18px;">
                                <div class="admin-dashboard-formbody">
                                    <h3 class="admin-dashboard-formtitle">@item.Title</h3>
                                    <p class="admin-dashboard-formtext">@item.Message</p>
                                    <div style="margin-top: 12px; display: flex; justify-content: flex-end;">
                                        <button type="button" class="admin-btn-outline" style="border-color: #ef4444; color: #ef4444;" disabled="@(isDeleting && deletingNoticeId == item.Id)" @onclick="() => DeleteNoticeAsync(item.Id)">
                                            @(isDeleting && deletingNoticeId == item.Id ? "Deleting..." : "Delete")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>
</section>

@code {
    private ViewMode mode = ViewMode.Explore;
    private bool isLoading;
    private string loadError = "";
    private bool isDeleting;
    private int? deletingExploreId;
    private int? deletingNoticeId;
    private List<ExplorePostItem> explorePosts = new();
    private List<NoticeItem> notices = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            var exploreTask = DiaryService.GetAdminListAsync<ExplorePostItem>("api/Admin/news");
            var noticesTask = DiaryService.GetAdminListAsync<NoticeItem>("api/Admin/announcements");
            await Task.WhenAll(exploreTask, noticesTask);
            explorePosts = exploreTask.Result;
            notices = noticesTask.Result;
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteExploreAsync(int id)
    {
        isDeleting = true;
        deletingExploreId = id;
        loadError = "";
        try
        {
            await DiaryService.DeleteNewsAsync(id);
            explorePosts = explorePosts.Where(x => x.Id != id).ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            deletingExploreId = null;
            isDeleting = false;
        }
    }

    private async Task DeleteNoticeAsync(int id)
    {
        isDeleting = true;
        deletingNoticeId = id;
        loadError = "";
        try
        {
            await DiaryService.DeleteAnnouncementAsync(id);
            notices = notices.Where(x => x.Id != id).ToList();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            deletingNoticeId = null;
            isDeleting = false;
        }
    }

    private void SelectMode(ViewMode nextMode)
    {
        mode = nextMode;
    }

    private string ModeButtonClass(ViewMode buttonMode)
    {
        return mode == buttonMode
            ? "admin-create-toggle-btn admin-create-toggle-btn-active"
            : "admin-create-toggle-btn";
    }

    private enum ViewMode
    {
        Explore,
        Notice
    }

    private sealed class ExplorePostItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private sealed class NoticeItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
