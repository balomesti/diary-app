@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<PageTitle>Diary App</PageTitle>

<div class="page">
    @if (IsMainPage())
    {
        <NavMenu />
    }

    <main class="main">
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool IsMainPage()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        // Only show NavMenu if we're not on the root (SignIn) or Register page
        return !string.IsNullOrEmpty(relativePath) && relativePath != "register";
    }
}
